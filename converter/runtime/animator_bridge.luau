-- UnityBridge/AnimatorBridge
-- Drives Roblox AnimationController/AnimationTrack using a config table
-- generated by animation_converter.py from Unity Animator state machines.
--
-- This module uses config-table-driven state machines with 1D blend tree
-- support and lazy animation track loading. It complements animator_runtime.luau
-- which uses JSON controller data with keyframe TweenService fallback.
--
-- Usage:
--   local AB = require(ReplicatedStorage.UnityBridge.AnimatorBridge)
--   local config = require(ReplicatedStorage:WaitForChild("Enemy_AnimatorConfig"))
--   local animator = AB.new(humanoid, config)
--   animator:SetFloat("speed", 5)
--   animator:SetTrigger("attack")
--
-- Config table format:
--   {
--     parameters = { speed = { type = "Float", default = 0 }, ... },
--     states = { Idle = { clip = "clipName", speed = 1, loop = true }, ... },
--     transitions = { { from = "Idle", to = "Walk", conditions = {...}, duration = 0.25 }, ... },
--     blendTrees = { Locomotion = { param = "speed", clips = { ... } } },
--     defaultState = "Idle",
--   }

local RunService = game:GetService("RunService")

-- All active AnimatorBridge instances, ticked by one shared Heartbeat connection
local _allInstances: { [number]: any } = {}
local _heartbeatConnection = nil

local AnimatorBridge = {}
AnimatorBridge.__index = AnimatorBridge

function AnimatorBridge.new(humanoidOrController, config)
	local self = setmetatable({}, AnimatorBridge)

	-- Accept either a Humanoid (has :FindFirstChildOfClass("Animator")) or AnimationController
	if humanoidOrController:IsA("Humanoid") then
		self._animator = humanoidOrController:FindFirstChildOfClass("Animator")
		if not self._animator then
			self._animator = Instance.new("Animator")
			self._animator.Parent = humanoidOrController
		end
	elseif humanoidOrController:IsA("AnimationController") then
		self._animator = humanoidOrController
	else
		warn("[AnimatorBridge] Expected Humanoid or AnimationController, got " .. humanoidOrController.ClassName)
		self._animator = humanoidOrController
	end

	self._config = config
	self._currentState = nil
	self._currentTrack = nil
	self._pendingTriggers = {} -- trigger params that fire once

	-- Initialize parameters from config defaults
	self._params = {}
	for name, def in pairs(config.parameters or {}) do
		self._params[name] = def.default
	end

	-- Lazy-loaded animation tracks: clipName → AnimationTrack
	self._tracks = {}

	-- Warned-once set for missing clips
	self._warnedClips = {}

	-- Register for shared tick
	table.insert(_allInstances, self)
	AnimatorBridge._ensureHeartbeat()

	-- Enter default state
	if config.defaultState and config.states and config.states[config.defaultState] then
		self:_enterState(config.defaultState)
	end

	return self
end

-- -----------------------------------------------------------------------
-- Parameter API (mirrors Unity Animator.SetFloat/SetBool/SetTrigger)
-- -----------------------------------------------------------------------

function AnimatorBridge:SetFloat(name, value)
	self._params[name] = value
end

function AnimatorBridge:SetBool(name, value)
	self._params[name] = value and true or false
end

function AnimatorBridge:SetInt(name, value)
	self._params[name] = math.floor(value)
end

function AnimatorBridge:SetTrigger(name)
	self._pendingTriggers[name] = true
	self._params[name] = true
end

function AnimatorBridge:GetFloat(name)
	return self._params[name] or 0
end

function AnimatorBridge:GetBool(name)
	return self._params[name] or false
end

function AnimatorBridge:GetInt(name)
	return self._params[name] or 0
end

-- -----------------------------------------------------------------------
-- Direct play (mirrors Animator.Play)
-- -----------------------------------------------------------------------

function AnimatorBridge:Play(stateName)
	if self._config.states and self._config.states[stateName] then
		self:_enterState(stateName)
	else
		warn("[AnimatorBridge] Unknown state: " .. tostring(stateName))
	end
end

-- -----------------------------------------------------------------------
-- Per-frame update (called from shared Heartbeat)
-- -----------------------------------------------------------------------

function AnimatorBridge:Update(dt)
	if not self._currentState then return end

	-- Evaluate transitions
	local fired = self:_evaluateTransitions()
	if fired then return end -- state changed, skip blend update this frame

	-- Update blend tree weights if active
	local stateConfig = self._config.states[self._currentState]
	if stateConfig and stateConfig.blendTree and self._config.blendTrees then
		self:_updateBlendTree(stateConfig.blendTree, dt)
	end

	-- Clear triggers after evaluation
	for name in pairs(self._pendingTriggers) do
		self._params[name] = false
	end
	table.clear(self._pendingTriggers)
end

-- -----------------------------------------------------------------------
-- State management (internal)
-- -----------------------------------------------------------------------

function AnimatorBridge:_enterState(stateName)
	local stateConfig = self._config.states[stateName]
	if not stateConfig then return end

	-- Stop current track with crossfade
	if self._currentTrack then
		self._currentTrack:Stop(0.25)
	end

	self._currentState = stateName

	-- Play the clip for this state
	if stateConfig.clip then
		local track = self:_getTrack(stateConfig.clip)
		if track then
			track:Play(0.25)
			track.Looped = stateConfig.loop or false

			local speed = stateConfig.speed or 1
			if speed ~= 1 then
				track:AdjustSpeed(speed)
			end

			self._currentTrack = track
		end
	elseif stateConfig.blendTree and self._config.blendTrees then
		-- Blend tree state: start all tracks, weights managed in Update
		self:_startBlendTree(stateConfig.blendTree)
	end
end

function AnimatorBridge:_getTrack(clipName)
	if self._tracks[clipName] then
		return self._tracks[clipName]
	end

	-- Lazy-load: create Animation instance and load it
	-- clipName here is the Unity clip name; in the real pipeline this would
	-- be mapped to an rbxassetid:// after upload. For now we search children.
	local animInstance = nil
	if self._animator then
		for _, child in ipairs(self._animator.Parent and self._animator.Parent:GetDescendants() or {}) do
			if child:IsA("Animation") and child.Name == clipName then
				animInstance = child
				break
			end
		end
	end

	if not animInstance then
		if not self._warnedClips[clipName] then
			warn("[AnimatorBridge] Animation not found: " .. tostring(clipName))
			self._warnedClips[clipName] = true
		end
		return nil
	end

	local track = self._animator:LoadAnimation(animInstance)
	self._tracks[clipName] = track
	return track
end

-- -----------------------------------------------------------------------
-- Transition evaluation
-- -----------------------------------------------------------------------

function AnimatorBridge:_evaluateTransitions()
	local transitions = self._config.transitions
	if not transitions then return false end

	for _, tr in ipairs(transitions) do
		if tr.from == self._currentState or tr.from == "Any" then
			-- Don't allow Any→same state
			if tr.from == "Any" and tr.to == self._currentState then
				continue
			end

			if self:_checkConditions(tr.conditions) then
				self:_enterState(tr.to)
				return true
			end
		end
	end

	return false
end

function AnimatorBridge:_checkConditions(conditions)
	if not conditions or #conditions == 0 then
		return false -- no conditions = don't auto-transition
	end

	for _, cond in ipairs(conditions) do
		local paramValue = self._params[cond.param]
		if paramValue == nil then
			return false
		end

		local op = cond.op
		local threshold = cond.value

		if op == ">" then
			if not (paramValue > threshold) then return false end
		elseif op == "<" then
			if not (paramValue < threshold) then return false end
		elseif op == "==" then
			if paramValue ~= threshold then return false end
		elseif op == "!=" then
			if paramValue == threshold then return false end
		elseif op == "trigger" then
			if not self._pendingTriggers[cond.param] then return false end
		end
	end

	return true
end

-- -----------------------------------------------------------------------
-- 1D Blend tree support
-- -----------------------------------------------------------------------

function AnimatorBridge:_startBlendTree(blendTreeName)
	local bt = self._config.blendTrees[blendTreeName]
	if not bt or not bt.clips then return end

	-- Start all tracks at weight 0
	for _, entry in ipairs(bt.clips) do
		local track = self:_getTrack(entry.clip)
		if track then
			track:Play(0.1)
			track.Looped = true
			track:AdjustWeight(0, 0.1)
		end
	end
end

function AnimatorBridge:_updateBlendTree(blendTreeName, dt)
	local bt = self._config.blendTrees[blendTreeName]
	if not bt or not bt.clips or #bt.clips == 0 then return end

	local paramValue = self._params[bt.param] or 0
	local clips = bt.clips

	-- Find the two clips we're between and interpolate weights
	for i, entry in ipairs(clips) do
		local track = self._tracks[entry.clip]
		if not track then continue end

		local weight = 0

		if i == 1 and paramValue <= entry.threshold then
			-- Below first threshold: full weight on first clip
			weight = 1
		elseif i == #clips and paramValue >= entry.threshold then
			-- Above last threshold: full weight on last clip
			weight = 1
		elseif i < #clips then
			local nextEntry = clips[i + 1]
			if paramValue >= entry.threshold and paramValue <= nextEntry.threshold then
				-- Between this and next: interpolate
				local range = nextEntry.threshold - entry.threshold
				if range > 0 then
					weight = 1 - (paramValue - entry.threshold) / range
				else
					weight = 1
				end
			elseif i > 1 then
				local prevEntry = clips[i - 1]
				if paramValue >= prevEntry.threshold and paramValue <= entry.threshold then
					local range = entry.threshold - prevEntry.threshold
					if range > 0 then
						weight = (paramValue - prevEntry.threshold) / range
					else
						weight = 0
					end
				end
			end
		end

		track:AdjustWeight(weight, 0.1)
	end
end

-- -----------------------------------------------------------------------
-- Cleanup
-- -----------------------------------------------------------------------

function AnimatorBridge:Destroy()
	-- Stop all tracks
	for _, track in pairs(self._tracks) do
		track:Stop(0)
		track:Destroy()
	end
	self._tracks = {}
	self._currentTrack = nil
	self._currentState = nil

	-- Remove from global tick list
	for i, inst in ipairs(_allInstances) do
		if inst == self then
			table.remove(_allInstances, i)
			break
		end
	end

	-- Disconnect heartbeat if no instances remain
	if #_allInstances == 0 and _heartbeatConnection then
		_heartbeatConnection:Disconnect()
		_heartbeatConnection = nil
	end
end

-- -----------------------------------------------------------------------
-- Shared Heartbeat (one connection for all instances)
-- -----------------------------------------------------------------------

function AnimatorBridge._ensureHeartbeat()
	if _heartbeatConnection then return end

	_heartbeatConnection = RunService.Heartbeat:Connect(function(dt)
		for _, inst in ipairs(_allInstances) do
			inst:Update(dt)
		end
	end)
end

return AnimatorBridge
