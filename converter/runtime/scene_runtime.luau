-- scene_runtime: PR4 generic host runtime for the scene-runtime contract.
--
-- Consumes the per-place ``scene_runtime_plan`` ModuleScript embedded
-- by ``write_output`` (Piece 5) and exposes the host surface every
-- contract-compliant MonoBehaviour module depends on (Pieces 1 + 6).
--
-- Architecture (six pieces):
--   Pieces 1-4 (transpiler contract, planner, ID stamping, packaging)
--   land in PR1-PR3b and produce the input artifacts this engine reads.
--   PR4 (this file) realizes Pieces 5 + 6: instantiate every
--   runtime-bearing MonoBehaviour, wire serialized references, run the
--   lifecycle, and provide the runtime object-model services.
--
-- Services (Piece 6):
--   * Component registry  -- ``self:GetComponent(name)`` -> peer module
--     or Roblox built-in component fallback (``Rigidbody`` / ``Button`` /
--     ``Collider`` / ``AudioSource`` / ``Animator``).
--   * Global lookup       -- ``host.findObjectOfType`` /
--     ``findGameObject`` / ``findGameObjectsWithTag`` (sees inactive).
--   * Lifecycle-scoped scheduler -- ``host.invoke`` /
--     ``invokeRepeating`` / ``cancelInvoke`` / ``startCoroutine``;
--     cancels every per-component task on ``OnDestroy``.
--   * Lifecycle-scoped event wiring -- ``host.connect(self, signal, fn)``;
--     dispatch gated on ``active && enabled`` (Unity-message-callback
--     semantics; rule (f) compliance partner).
--   * Dynamic component creation -- ``host.addComponent(go, scriptId,
--     config?)``; instantiate at runtime, register, run
--     ``Awake -> OnEnable -> Start``.
--   * Prefab instantiation -- ``host.instantiatePrefab(prefab_id,
--     parent, cframe, externalRefs?)``; clones a template and drives
--     intra-prefab lifecycle.
--   * Recursive teardown -- ``host.destroy(target)``; DFS deepest-first
--     ``OnDisable`` -> ``OnDestroy``, idempotent, registry-aware.
--   * Cross-domain reference policy (v1) -- the host injects ``nil`` and
--     logs a structured warning when a serialized ref crosses the
--     ``client``/``server`` boundary (the conversion-time edge report
--     surfaces the same edges in ``UNCONVERTED.md``).
--
-- Test harness:
--   The module's surface is constructed by ``SceneRuntime.new(services,
--   plan)`` so tests can inject mock Roblox primitives (``task``,
--   ``Instance``, signal Connect/Disconnect, etc.). Production
--   entrypoints (SceneRuntimeClient/Server, generated by
--   ``write_output``) supply the real Roblox services.

local SceneRuntime = {}
SceneRuntime.__index = SceneRuntime

-- Phase 1 (relation #8): the pipeline length scale (Unity metres -> Roblox studs). The transpiler
-- emits this same constant inline in per-script Luau (code_transpiler.py); the host needs its own
-- module-scope copy to apply the faithful launch velocity in ``applyImpulse``.
local STUDS_PER_METER = 3.571

-- ---------------------------------------------------------------------
-- R4-P1.3: Unity -> Roblox class-name translation for the GetComponent
-- built-in fallback.
--
-- Contract-emitted MonoBehaviours call ``self:GetComponent("Rigidbody")``
-- with the Unity type name. Roblox's ``findFirstChildWhichIsA`` (and
-- ``Instance:IsA``) only knows Roblox class names, so the Unity names
-- never matched: ``Rigidbody`` -> nil, ``BoxCollider`` -> nil, etc.
-- A converted ``Rigidbody`` is the lowered ``BasePart`` on the Roblox
-- side; a converted ``MeshRenderer`` is a ``MeshPart``; and so on.
--
-- We translate at lookup time (rather than at transpile time) so the
-- host can be updated independently of the contract-emitted modules:
-- a downstream operator who adds a new Unity component type can extend
-- this table without re-running the converter. ``Transform`` is the
-- one special case -- in Unity it's the GameObject's own transform, so
-- we return a sentinel meaning "self" and the caller short-circuits.
--
-- Unknown Unity names fall through to the raw lookup so:
--   (a) operators get the same failure mode as pre-fix code if a name
--       isn't covered yet (no silent regression).
--   (b) Roblox class names passed directly (``"BasePart"``) still work.
local _UNITY_TO_ROBLOX_CLASS: {[string]: string} = {
	-- Physics
	Rigidbody = "BasePart",
	Rigidbody2D = "BasePart",
	BoxCollider = "BasePart",
	SphereCollider = "BasePart",
	CapsuleCollider = "BasePart",
	MeshCollider = "BasePart",
	WheelCollider = "BasePart",
	CharacterController = "BasePart",
	-- Rendering
	MeshRenderer = "MeshPart",
	SkinnedMeshRenderer = "MeshPart",
	MeshFilter = "MeshPart",
	-- Camera / lighting / audio
	Camera = "Camera",
	Light = "Light",
	AudioSource = "Sound",
	AudioListener = "Sound",
	-- Animation
	Animator = "AnimationController",
	Animation = "AnimationController",
	-- UI (Unity's UnityEngine.UI.* -> Roblox Gui*; the converter
	-- typically lowers Button to TextButton/ImageButton, so accept the
	-- abstract GuiButton).
	Button = "GuiButton",
	Image = "ImageLabel",
	RawImage = "ImageLabel",
	Text = "TextLabel",
	Canvas = "ScreenGui",
	-- Particle / VFX
	ParticleSystem = "ParticleEmitter",
	TrailRenderer = "Trail",
	LineRenderer = "Beam",
}

-- Sentinel: ``GetComponent("Transform")`` returns the GameObject's own
-- root instance (Unity Transform is intrinsic to every GameObject).
local _CLASS_TRANSFORM_SELF = "__transform_self__"
_UNITY_TO_ROBLOX_CLASS.Transform = _CLASS_TRANSFORM_SELF
_UNITY_TO_ROBLOX_CLASS.RectTransform = _CLASS_TRANSFORM_SELF

-- ---------------------------------------------------------------------
-- Service surface accepted by ``SceneRuntime.new``.
--
-- A *services* table bundles every Roblox primitive the engine touches.
-- The entrypoint scripts inject the real implementations; the test
-- harness injects controllable stubs.
--
-- Required fields:
--   task           -- ``{ spawn, defer, delay, wait }``
--   warn           -- ``function(...)`` (defaults to global ``warn``)
--   resolveModule  -- ``function(script_id, module_path) -> module``;
--                     loads a transpiled MonoBehaviour ModuleScript by
--                     plan-row id and resolved DataModel path.
--   workspaceFind  -- ``function(scene_runtime_id) -> Instance | nil``;
--                     looks an Instance up by its ``_SceneRuntimeId``
--                     attribute. Implementation typically caches a
--                     workspace + UI scan keyed by that attribute.
--   findFirstChildWhichIsA -- ``function(instance, class_name) ->
--                     Instance | nil``; used by GetComponent fallback.
--   heartbeat      -- a Roblox-shaped signal (``signal:Connect(fn)``
--                     returns a connection). Drives Update / LateUpdate.
--   fixedStep      -- number (seconds) for FixedUpdate accumulator
--                     (Unity's default is 0.02).
--   now            -- ``function() -> number`` (monotonic seconds).
--   players        -- the ``Players`` service (or a stub exposing
--                     ``GetPlayerFromCharacter``). Used by
--                     ``playerFromTouch`` / ``isPlayerTouch`` to
--                     normalize a touched BasePart to its owning Player.
--                     Optional: nil -> ``playerFromTouch`` returns nil.
-- ---------------------------------------------------------------------

-- ---------------------------------------------------------------------
-- Constructor
-- ---------------------------------------------------------------------

function SceneRuntime.new(services, plan)
	assert(type(services) == "table", "SceneRuntime.new: services required")
	assert(type(plan) == "table", "SceneRuntime.new: plan required")

	local self = setmetatable({}, SceneRuntime)
	self._services = services
	self._plan = plan
	self._warn = services.warn or function(...) end

	-- Live registry: ``<game_object_id, list[component_instance]>``.
	-- Mutated by ``instantiatePrefab`` / ``addComponent`` / ``destroy``.
	self._componentsByGameObject = {}

	-- Reverse map: component instance -> {scriptId, gameObjectId,
	-- ownerKind, ownerRef}. Lets the scheduler/event-wiring services
	-- look up provenance for a ``self`` without forcing each
	-- MonoBehaviour to carry the metadata.
	self._meta = {}

	-- Per-component task table for the lifecycle-scoped scheduler.
	-- ``_tasks[componentInstance] = { handle1, handle2, ... }``;
	-- ``OnDestroy`` cancels every handle.
	self._tasks = {}

	-- Per-component subscription table for ``host.connect``:
	-- ``_subs[componentInstance] = { {signal=, fn=, conn=, armed=}, ... }``.
	-- ``OnDestroy`` disconnects them all; gate transitions rearm them.
	self._subs = {}

	-- R4-P1.2: per-GameObject ``activeSelf`` vs ``activeInHierarchy``.
	-- Unity tracks BOTH per-GameObject flags:
	--   * ``activeSelf``         -- the GO's OWN active flag (authored
	--                              or explicitly set via ``setActive``).
	--                              Stable across ancestor cascades.
	--   * ``activeInHierarchy``  -- ``activeSelf`` AND every ancestor's
	--                              ``activeSelf``. The dispatch gate.
	-- Pre-R4 the host conflated them: the ``setActive`` cascade
	-- overwrote each descendant's stored ``activeSelf`` to the toggled
	-- value, so a child authored inactive would wrongly re-activate when
	-- its parent toggled back on. Fix: keep the per-GO ``activeSelf``
	-- map (mutated ONLY by a direct ``setActive(go, ...)`` on THAT GO);
	-- cache the computed ``activeInHierarchy`` per GO; gate every
	-- dispatch on ``activeInHierarchy AND enabled``. Per-component meta
	-- carries both flags so the existing per-component code paths
	-- (Awake/Start/OnEnable bookkeeping) still see live values without
	-- a second indirection on every check.
	self._goActiveSelf = {}          -- goId -> bool (authored)
	self._goActiveInHierarchy = {}   -- goId -> bool (computed gate)
	-- R5-P1.2: per-GameObject parent map (goId -> parentGoId). Populated
	-- at ``start()`` from each planner instance's
	-- ``parent_game_object_id`` extra. The host walks this map UP when
	-- computing ``activeInHierarchy`` so a child whose ancestor is
	-- authored inactive boots dormant (and ``setActive(grandchild,
	-- true)`` on a deeply-nested GO correctly checks every ancestor).
	-- A goId absent from this map is treated as a planner-root: the
	-- upward walk stops and the ancestor chain above it is implicitly
	-- active. This bounds the fix to GOs the planner walked
	-- (runtime-bearing ancestors); GOs without a MonoBehaviour aren't
	-- tracked but default to "active", which matches Unity's
	-- "no-MB GameObjects can't be inactive without an authored flag" rule.
	self._goParentId = {}            -- goId -> parentGoId | nil

	-- Global lookups for ``findObjectOfType`` / ``findGameObject`` /
	-- ``findGameObjectsWithTag``. Built once at start, updated on
	-- ``instantiatePrefab`` / ``addComponent`` / ``destroy``.
	self._byClass = {}      -- scriptStem -> list[component]
	self._byName = {}       -- gameObjectName -> list[component]
	self._byTag = {}        -- tag -> list[component]

	-- Engine-level ``instance_id -> component`` registry. Populated by
	-- BOTH the synchronous build passes (scene + prefab) AND the deferred
	-- batch. The per-owner ``componentByInstanceId`` locals are discarded
	-- when ``start()`` returns, so a deferred component completing late has
	-- no other way to resolve a ``component``-kind outbound ref to a
	-- SYNCHRONOUSLY-built peer (the symmetric mirror of the inbound
	-- back-patch). instance_ids are planner-namespaced
	-- (``<scene|prefab>:<file_id>``) so they're globally unique across
	-- owners; the deferred wire pass resolves against the UNION of this
	-- registry and the batch-built set.
	self._componentByInstanceId = {}

	-- Track which prefab instances we've spawned, keyed by clone
	-- Instance (so ``destroy(clone)`` can find the descendants to tear
	-- down without re-walking).
	self._prefabClones = {}

	-- Monotonic counter for runtime-spawn placement ids. Each
	-- ``instantiatePrefab`` mints ``_rt_<seq>`` and stamps every cloned
	-- descendant's ``_SceneRuntimeId`` with that prefix so internal map
	-- keys (``_componentsByGameObject``, ``_goActiveSelf``, ...) and the
	-- read-path resolvers (``services.getInstanceId`` / the cascade
	-- helpers) agree on a per-placement identity. Without this the
	-- prefab-local goid collides across placements and ``setActive`` /
	-- ``destroy`` on the second clone silently no-ops.
	self._rtPlacementSeq = 0

	-- FixedUpdate accumulator.
	self._fixedStep = services.fixedStep or (1 / 50)
	self._fixedAccum = 0

	-- Track per-component (component, gameObjectId) destroy status so
	-- ``host.destroy(parent)`` is idempotent.
	self._destroyed = {}

	return self
end

-- ---------------------------------------------------------------------
-- Registry helpers
-- ---------------------------------------------------------------------

function SceneRuntime:_register(componentInstance, meta)
	local goId = meta.gameObjectId
	local bucket = self._componentsByGameObject[goId]
	if not bucket then
		bucket = {}
		self._componentsByGameObject[goId] = bucket
	end
	table.insert(bucket, componentInstance)
	self._meta[componentInstance] = meta

	local stem = meta.stem or meta.scriptId or ""
	if stem ~= "" then
		local list = self._byClass[stem]
		if not list then list = {}; self._byClass[stem] = list end
		table.insert(list, componentInstance)
	end
	-- ``findGameObject`` / ``findGameObjectsWithTag`` index by the
	-- Roblox GameObject Instance (per the Unity contract --
	-- ``GameObject.Find`` returns a GameObject, not a component). One
	-- GameObject may host several components; dedupe via _goByName /
	-- _goByTag so a GameObject is listed once per name+tag.
	local goInst = meta.gameObjectInstance
	if goInst ~= nil then
		local name = meta.gameObjectName or ""
		if name ~= "" then
			local list = self._byName[name]
			if not list then list = {}; self._byName[name] = list end
			local present = false
			for _, x in ipairs(list) do if x == goInst then present = true; break end end
			if not present then table.insert(list, goInst) end
		end
		local tag = meta.tag or ""
		if tag ~= "" then
			local list = self._byTag[tag]
			if not list then list = {}; self._byTag[tag] = list end
			local present = false
			for _, x in ipairs(list) do if x == goInst then present = true; break end end
			if not present then table.insert(list, goInst) end
		end
	end
end

function SceneRuntime:_unregister(componentInstance)
	local meta = self._meta[componentInstance]
	if not meta then return end
	local function ripValue(t, key, value)
		local list = t[key]
		if not list then return end
		for i = #list, 1, -1 do
			if list[i] == value then
				table.remove(list, i)
			end
		end
	end
	ripValue(self._componentsByGameObject, meta.gameObjectId, componentInstance)
	ripValue(self._byClass, meta.stem or "", componentInstance)
	-- ``_byName`` / ``_byTag`` are keyed by GameObject Instance; only
	-- drop the GO when the LAST component on that GO unregisters
	-- (multiple components can share the same GameObject).
	local goId = meta.gameObjectId
	local remaining = self._componentsByGameObject[goId]
	if not remaining or #remaining == 0 then
		local goInst = meta.gameObjectInstance
		if goInst ~= nil then
			ripValue(self._byName, meta.gameObjectName or "", goInst)
			ripValue(self._byTag, meta.tag or "", goInst)
		end
	end
	-- Clear the engine union registry entry (codex r3 BLOCKING): without this
	-- a destroyed component lingered in ``_componentByInstanceId`` and a later
	-- deferred wire pass could bind a peer's ref to the dead comp.
	-- ``registryKey`` is the EXACT placement-scoped key written at build time;
	-- only drop it when it still points at THIS component (a later placement /
	-- runtime spawn may have legitimately overwritten the key).
	if meta.registryKey ~= nil
	   and self._componentByInstanceId[meta.registryKey] == componentInstance then
		self._componentByInstanceId[meta.registryKey] = nil
	end
	self._meta[componentInstance] = nil
end

-- ---------------------------------------------------------------------
-- Touch / collision helpers (Piece 6 -- generic touch contract)
--
-- A prefab-placement component's ``self.gameObject`` is a Roblox
-- ``Model`` (the resolved Instance is the placed prefab root), but the
-- contract taught ``self.host:connect(self.gameObject.Touched, ...)`` --
-- and ``.Touched`` is a ``BasePart``-only signal. On a Model it threw
-- ``Touched is not a valid member of Model`` and every Pickup / Door /
-- Turret died in ``Awake``. ``getTouchPart`` resolves a representative
-- BasePart to host the signal; ``connectGameObjectSignal`` wires it
-- through the lifecycle-tracked ``connect`` machinery so the
-- subscription is gated / disarmed / cleaned up exactly like
-- ``self.host:connect``.
--
-- Selection logic mirrors the legacy (non-generic) trigger-part finder
-- the generic contract regressed (code_transpiler.py findTriggerPart).
-- PrimaryPart is deliberately NOT used as the key: it carries pivot
-- semantics and PrimaryPart emission is documented unsupported.
-- ---------------------------------------------------------------------

-- Synthetic / authored trigger-child names the converter (or a Unity
-- prefab author) emits for proximity volumes. ``TriggerZone`` is the
-- synthetic child scene_converter emits for a Unity Collider-with-trigger.
local _TRIGGER_CHILD_NAMES: {string} = {
	"TriggerZone", "Trigger", "Collider", "Colliders", "Detector",
	"Sensor", "Hitbox", "Range", "ProximityVolume", "PickupTouchDetector",
}

local function _isBasePart(inst): boolean
	return inst ~= nil
		and type(inst.IsA) == "function"
		and inst:IsA("BasePart")
end

-- Returns true when ``inst`` looks like an explicitly-named trigger
-- volume (matches a known name OR has ``*TouchDetector*`` / ``*Trigger*``
-- in its name) that can actually receive touches.
local function _looksLikeNamedTrigger(inst): boolean
	if not _isBasePart(inst) then return false end
	if inst.CanTouch == false then return false end
	local name = inst.Name
	for _, n in ipairs(_TRIGGER_CHILD_NAMES) do
		if name == n then return true end
	end
	if string.find(name, "TouchDetector") or string.find(name, "Trigger") then
		return true
	end
	return false
end

-- Returns true when ``inst`` is a BasePart explicitly stamped by the
-- converter as a trigger detection volume (``_IsTriggerVolume`` attribute)
-- and can still receive touches. The converter stamps this on every
-- trigger-collider-derived Part (the standalone transparent trigger Part
-- and the synthetic ``TriggerZone`` child) so the host can resolve the
-- detection radius without relying on name heuristics.
local function _isMarkedTriggerVolume(inst): boolean
	if not _isBasePart(inst) then return false end
	if inst.CanTouch == false then return false end
	if type(inst.GetAttribute) ~= "function" then return false end
	local ok, marked = pcall(function()
		return inst:GetAttribute("_IsTriggerVolume")
	end)
	return ok and marked == true
end

-- ``_findMarkedTriggerVolume(go) -> BasePart?``: scan ``go`` itself (when
-- it is a BasePart) and its descendants (when it is a Model) for a
-- ``_IsTriggerVolume``-marked BasePart with CanTouch. Returns the first
-- match or nil. Lets ``getTouchPart`` prefer an explicit trigger volume
-- over a bare BasePart ``go`` (e.g. a BasePart-root turret whose 285-stud
-- ``Collider`` child is the real detection radius).
local function _findMarkedTriggerVolume(go): BasePart?
	if go == nil then return nil end
	if _isMarkedTriggerVolume(go) then return go end
	if type(go.GetDescendants) ~= "function" then return nil end
	local ok, descendants = pcall(function() return go:GetDescendants() end)
	if not ok or type(descendants) ~= "table" then return nil end
	for _, d in ipairs(descendants) do
		if _isMarkedTriggerVolume(d) then return d end
	end
	return nil
end

-- ``getTouchPart(go, preferTriggerVolume) -> BasePart?``: resolve a
-- representative part to host a Touched/TouchEnded signal for a GameObject.
--   * BasePart  -> itself.
--   * Model     -> tiered descendant search:
--       (1) a named trigger child (TriggerZone / *TouchDetector* /
--           *Trigger* ...) with CanTouch;
--       (2) the first invisible (Transparency>=0.99) non-MeshPart
--           BasePart with CanTouch;
--       (3) the first BasePart descendant.
--     PrimaryPart is never the primary key.
--   * anything else / no part -> nil.
--
-- ``preferTriggerVolume`` (default false): when true, a converter-stamped
-- ``_IsTriggerVolume`` volume on ``go`` (itself or a descendant) wins over
-- the bare-BasePart passthrough and tier search -- so a BasePart-root turret
-- resolves its detection-radius Collider child, not the small visible body.
-- ONLY the OnTriggerStay proximity poll (``connectGameObjectSignalStay``)
-- passes this; the shared edge resolver (``connectGameObjectSignal`` for
-- ``Touched``/``TouchEnded`` -- OnTriggerEnter/Exit/OnCollision*) omits it so
-- those callbacks keep binding to the physical body / original tier result.
function SceneRuntime:getTouchPart(go, preferTriggerVolume)
	if go == nil then return nil end
	-- Stay-poll only: prefer an explicit, converter-stamped trigger volume
	-- over any other resolution (including the bare-BasePart passthrough
	-- below). A childless BasePart with no marked volume still falls through
	-- to the passthrough, so the passthrough behavior is preserved. The edge
	-- resolver passes nil/false here -> ORIGINAL pre-PR resolution.
	if preferTriggerVolume then
		local marked = _findMarkedTriggerVolume(go)
		if marked ~= nil then
			return marked
		end
	end
	if _isBasePart(go) then
		return go
	end
	if type(go.IsA) ~= "function" or not go:IsA("Model") then
		return nil
	end
	local descendants = go:GetDescendants()
	-- Tier 1: an explicitly-named trigger child.
	for _, d in ipairs(descendants) do
		if _looksLikeNamedTrigger(d) then
			return d
		end
	end
	-- Tier 2: an invisible non-mesh trigger volume with CanTouch.
	for _, d in ipairs(descendants) do
		if _isBasePart(d)
			and d.CanTouch ~= false
			and (d.Transparency or 0) >= 0.99
			and not d:IsA("MeshPart")
		then
			return d
		end
	end
	-- Tier 3: any BasePart descendant.
	for _, d in ipairs(descendants) do
		if _isBasePart(d) then
			return d
		end
	end
	return nil
end

-- ``connectGameObjectSignal(comp, go, signalName, fn) -> connection?``:
-- resolve the touch part via ``getTouchPart`` and connect
-- ``part[signalName]`` (e.g. "Touched" / "TouchEnded") through the
-- lifecycle-tracked ``connect`` machinery. Fails soft (warns + returns
-- nil) when no part resolves -- never throws.
function SceneRuntime:connectGameObjectSignal(comp, go, signalName, fn)
	assert(type(fn) == "function",
		"connectGameObjectSignal: fn must be function")
	assert(type(signalName) == "string" and signalName ~= "",
		"connectGameObjectSignal: signalName required")
	local part = self:getTouchPart(go)
	if part == nil then
		self._warn(string.format(
			"[scene_runtime] connectGameObjectSignal: no touch part on %s",
			tostring(go)))
		return nil
	end
	local signal = part[signalName]
	if signal == nil then
		self._warn(string.format(
			"[scene_runtime] connectGameObjectSignal: %s has no %s signal",
			tostring(part), tostring(signalName)))
		return nil
	end
	return self:connect(comp, signal, fn)
end

-- Throttle for the OnTriggerStay overlap poll (seconds between sweeps).
-- One ``GetPartsInPart`` per turret per tick is bounded; ~0.13s is the
-- per-frame analog of Unity's per-physics-frame OnTriggerStay without
-- flooding the dispatch every Heartbeat.
local _STAY_POLL_INTERVAL = 0.13

-- ``connectGameObjectSignalStay(comp, go, fn) -> connection?``: generic
-- host primitive emulating Unity ``OnTriggerStay``. Resolves the trigger
-- volume via ``getTouchPart`` then arms a throttled overlap poll on the
-- engine Heartbeat: every ~``_STAY_POLL_INTERVAL`` seconds it sweeps
-- ``workspace:GetPartsInPart(triggerPart)`` and fires ``fn(hit)`` once per
-- overlapping part (the per-frame analog of OnTriggerStay) -- so a player
-- STANDING inside the volume (no ``.Touched`` edge) is still detected.
--
-- Routed through the lifecycle-tracked ``connect`` machinery (NOT
-- ``invokeRepeating``/``_trackTask``): it disarms via ``_disarmSubs`` on
-- disable/destroy and rearms via ``_rearmSubs`` on enable, gating on
-- ``active && enabled`` like every other subscription. Iterates a stable
-- snapshot of the overlap result and re-checks component liveness before
-- each callback (``fn`` may destroy the component mid-iteration). Fails
-- soft (warn + nil) when no trigger part resolves, mirroring
-- ``connectGameObjectSignal``.
function SceneRuntime:connectGameObjectSignalStay(comp, go, fn)
	assert(type(fn) == "function",
		"connectGameObjectSignalStay: fn must be function")
	-- The proximity poll genuinely wants the large sight volume: prefer the
	-- converter-stamped ``_IsTriggerVolume`` over the small visible body.
	local part = self:getTouchPart(go, true)
	if part == nil then
		self._warn(string.format(
			"[scene_runtime] connectGameObjectSignalStay: no touch part on %s",
			tostring(go)))
		return nil
	end
	-- Heartbeat is optional across the runtime (the engine update loop
	-- guards ``if self._services.heartbeat then ...``). Soft-fail here
	-- rather than letting ``connect``'s ``signal ~= nil`` assert throw.
	local heartbeat = self._services.heartbeat
	if heartbeat == nil then
		self._warn(string.format(
			"[scene_runtime] connectGameObjectSignalStay: no heartbeat service for %s",
			tostring(go)))
		return nil
	end
	local engine = self
	local nowFn = self._services.now or os.clock
	local lastTick = 0
	return self:connect(comp, heartbeat, function()
		local now = nowFn()
		if now - lastTick < _STAY_POLL_INTERVAL then return end
		lastTick = now
		-- Snapshot the overlap result so a callback that mutates the
		-- workspace mid-iteration can't reshape the list we're walking.
		local ok, hits = pcall(function()
			return workspace:GetPartsInPart(part)
		end)
		if not ok or type(hits) ~= "table" then return end
		for _, hit in ipairs(hits) do
			-- Liveness/re-entrancy + disable guard: ``fn`` may destroy OR
			-- disable ``comp`` mid-sweep. The outer ``connect`` gate only
			-- checks once per tick, so re-check the lifecycle gate before
			-- each callback so a mid-sweep disable stops remaining hits.
			if engine._destroyed[comp] or not engine:_isGateOpen(comp) then
				return
			end
			fn(hit)
		end
	end)
end

-- ``playerFromTouch(other) -> Player?``: given the BasePart that fired a
-- Touched signal, walk ancestors to the character Model and return the
-- owning Player. R15 / accessory parts have the Accessory model as their
-- immediate parent, so a flat ``other.Parent`` lookup misses them --
-- ``FindFirstAncestorWhichIsA("Model")`` resolves both. Mirrors the
-- working pattern in pickup_runtime.luau + the script_coherence rewrite.
function SceneRuntime:playerFromTouch(other)
	if other == nil then return nil end
	local players = self._services.players
	if players == nil then return nil end
	-- Walk ancestors looking for the character Model -- a Model that
	-- carries a Humanoid. This handles BOTH the common case (limb whose
	-- immediate Parent is the character) AND accessory-mounted parts
	-- (handle -> Accessory model -> character), where a single
	-- ``other.Parent`` or nearest-ancestor-Model lookup picks the wrong
	-- Model. Cap the climb so a deep workspace tree can't loop forever.
	local node = other.Parent
	local guard = 0
	while node ~= nil and guard < 16 do
		guard += 1
		if type(node.IsA) == "function" and node:IsA("Model")
			and type(node.FindFirstChildWhichIsA) == "function"
			and node:FindFirstChildWhichIsA("Humanoid")
		then
			return players:GetPlayerFromCharacter(node)
		end
		node = node.Parent
	end
	return nil
end

-- ``isPlayerTouch(other) -> boolean``: convenience boolean wrapper around
-- ``playerFromTouch`` for the common ``if self.host.isPlayerTouch(other)``
-- gate.
function SceneRuntime:isPlayerTouch(other)
	return self:playerFromTouch(other) ~= nil
end

-- ---------------------------------------------------------------------
-- Host surface bound onto each component as ``self.host``
-- ---------------------------------------------------------------------

function SceneRuntime:_makeHostSurface(owner)
	-- Capture ``self`` (the SceneRuntime instance) once. Each component's
	-- ``self.host`` is its own per-instance table -- the closures below
	-- can default ``comp`` to ``owner`` when colon-form sugar is used
	-- (e.g. ``self.host:connect(signal, fn)`` per rule (f)). Dotted form
	-- (``self.host.connect(self, signal, fn)`` per the design doc) also
	-- works since ``arg1 ~= host`` selects the dotted-form branch.
	local engine = self
	local host
	host = {
		instantiatePrefab = function(arg1, arg2, arg3, arg4, arg5)
			-- Colon form: host:instantiatePrefab(prefab_id, parent, cframe, externalRefs)
			--   arg1 = host, arg2 = prefab_id, arg3 = parent, arg4 = cframe, arg5 = externalRefs
			-- Dotted:      host.instantiatePrefab(prefab_id, parent, cframe, externalRefs)
			--   arg1 = prefab_id, arg2 = parent, arg3 = cframe, arg4 = externalRefs
			-- R3-P2: the four-arg colon-form wrapper dropped
			-- externalRefs entirely by collapsing two arg shapes into
			-- one set of formals. Five-arg shape preserves both.
			if arg1 == host then
				return engine:instantiatePrefab(arg2, arg3, arg4, arg5)
			end
			return engine:instantiatePrefab(arg1, arg2, arg3, arg4)
		end,
		addComponent = function(arg1, arg2, arg3, arg4)
			-- Dotted: addComponent(go, scriptId, config)
			-- Colon:  host:addComponent(go, scriptId, config)
			if arg1 == host then
				return engine:addComponent(arg2, arg3, arg4)
			end
			return engine:addComponent(arg1, arg2, arg3)
		end,
		destroy = function(arg1, arg2)
			if arg1 == host then
				return engine:destroy(arg2)
			end
			return engine:destroy(arg1)
		end,
		setActive = function(arg1, arg2, arg3)
			if arg1 == host then
				return engine:setActive(arg2, arg3)
			end
			return engine:setActive(arg1, arg2)
		end,
		-- Phase 1 (relation #8): faithful launch for a force-launched body. The AI lowers
		-- ``Rigidbody.AddForce(f)`` to ``self.host.applyImpulse(part, f)``; the host applies the
		-- stud-scaled velocity change so the bullet flies despite the inflated Roblox mass.
		applyImpulse = function(arg1, arg2, arg3)
			-- Dotted: host.applyImpulse(part, force); colon: host:applyImpulse(part, force)
			if arg1 == host then
				return engine:applyImpulse(arg2, arg3)
			end
			return engine:applyImpulse(arg1, arg2)
		end,
		findObjectOfType = function(arg1, arg2)
			if arg1 == host then return engine:findObjectOfType(arg2) end
			return engine:findObjectOfType(arg1)
		end,
		findGameObject = function(arg1, arg2)
			if arg1 == host then return engine:findGameObject(arg2) end
			return engine:findGameObject(arg1)
		end,
		findGameObjectsWithTag = function(arg1, arg2)
			if arg1 == host then return engine:findGameObjectsWithTag(arg2) end
			return engine:findGameObjectsWithTag(arg1)
		end,
		invoke = function(arg1, arg2, arg3, arg4)
			-- Dotted: invoke(comp, method, delay); colon: host:invoke(method, delay)
			if arg1 == host then
				return engine:invoke(owner, arg2, arg3)
			end
			return engine:invoke(arg1, arg2, arg3)
		end,
		invokeRepeating = function(arg1, arg2, arg3, arg4, arg5)
			if arg1 == host then
				return engine:invokeRepeating(owner, arg2, arg3, arg4)
			end
			return engine:invokeRepeating(arg1, arg2, arg3, arg4)
		end,
		cancelInvoke = function(arg1, arg2, arg3)
			if arg1 == host then
				return engine:cancelInvoke(owner, arg2)
			end
			return engine:cancelInvoke(arg1, arg2)
		end,
		startCoroutine = function(arg1, arg2, arg3)
			if arg1 == host then
				return engine:startCoroutine(owner, arg2)
			end
			return engine:startCoroutine(arg1, arg2)
		end,
		connect = function(arg1, arg2, arg3)
			-- Two calling forms (the contract+verifier+prompt teach the
			-- colon form per rule (f)):
			--   host.connect(comp, signal, fn)   -- dotted
			--   host:connect(signal, fn)         -- colon (arg1 = host)
			if arg1 == host then
				return engine:connect(owner, arg2, arg3)
			end
			return engine:connect(arg1, arg2, arg3)
		end,
		getTouchPart = function(arg1, arg2)
			-- Colon: host:getTouchPart(go) -> arg1=host, arg2=go
			-- Dotted: host.getTouchPart(go) -> arg1=go
			if arg1 == host then
				return engine:getTouchPart(arg2)
			end
			return engine:getTouchPart(arg1)
		end,
		connectGameObjectSignal = function(arg1, arg2, arg3, arg4)
			-- Colon: host:connectGameObjectSignal(go, signalName, fn)
			--   arg1=host, arg2=go, arg3=signalName, arg4=fn
			-- Dotted: host.connectGameObjectSignal(go, signalName, fn)
			--   arg1=go, arg2=signalName, arg3=fn
			-- The contract teaches the colon form; the subscription is
			-- owned by ``owner`` so it tears down with the component.
			if arg1 == host then
				return engine:connectGameObjectSignal(owner, arg2, arg3, arg4)
			end
			return engine:connectGameObjectSignal(owner, arg1, arg2, arg3)
		end,
		connectGameObjectSignalStay = function(arg1, arg2, arg3)
			-- Colon: host:connectGameObjectSignalStay(go, fn)
			--   arg1=host, arg2=go, arg3=fn
			-- Dotted: host.connectGameObjectSignalStay(go, fn)
			--   arg1=go, arg2=fn
			-- The contract teaches the colon form; the subscription is
			-- owned by ``owner`` so it tears down with the component.
			if arg1 == host then
				return engine:connectGameObjectSignalStay(owner, arg2, arg3)
			end
			return engine:connectGameObjectSignalStay(owner, arg1, arg2)
		end,
		playerFromTouch = function(arg1, arg2)
			if arg1 == host then
				return engine:playerFromTouch(arg2)
			end
			return engine:playerFromTouch(arg1)
		end,
		isPlayerTouch = function(arg1, arg2)
			if arg1 == host then
				return engine:isPlayerTouch(arg2)
			end
			return engine:isPlayerTouch(arg1)
		end,
		-- Public per-player read surface (P1-4/P2-G). A NARROW table closing
		-- over ``engine`` — exposes ONLY the public ``getLookCFrame`` read so
		-- Phase 3's Shoot raycast can reach ``self.host.player:getLookCFrame()``
		-- without an interface change. It is NOT the raw SceneRuntime: internal
		-- scheduling state (``engine._player`` / ``_services`` / the per-frame
		-- brackets / ``start``) is NOT reachable through it, matching the
		-- authoritative "dedicated embodiment object" boundary.
		player = {
			getLookCFrame = function(arg1)
				-- Colon form ``host.player:getLookCFrame()`` -> arg1 = the
				-- player table; dotted -> arg1 = nil. Either way dispatch the
				-- engine's public method (no ``self``-dependent state here).
				return engine:getLookCFrame()
			end,
			teleport = function(arg1, arg2)
				-- Colon form ``host.player:teleport(cf)`` -> arg1 = the player
				-- table, arg2 = cf. Dotted ``host.player.teleport(cf)`` -> arg1 =
				-- cf. Select the CFrame from whichever slot carries it. NON-load-
				-- bearing client REQUEST (D7) -> server applies via the RemoteEvent.
				local cf = arg1
				if arg2 ~= nil then cf = arg2 end
				return engine:_playerTeleport(cf)
			end,
			applyRecoil = function(arg1, arg2)
				-- The Phase-4 directive advertises ``host.player:applyRecoil``;
				-- the AI's Shoot calls it, so the surface MUST implement it
				-- (caller/callee contract — a missing method throws in Update,
				-- caught at the Phase-5 cold-Studio verify). Colon form -> arg1 =
				-- the player table, arg2 = delta; dotted -> arg1 = delta. The
				-- number type-guard in ``_playerApplyRecoil`` makes the colon-
				-- with-no-arg call a safe no-op.
				local delta = arg1
				if arg2 ~= nil then delta = arg2 end
				return engine:_playerApplyRecoil(delta)
			end,
		},
	}
	return host
end

-- ---------------------------------------------------------------------
-- Instance construction
-- ---------------------------------------------------------------------

function SceneRuntime:_buildComponent(scriptId, gameObjectInstance, gameObjectId,
                                       gameObjectName, config, ownerKind, ownerRef)
	local moduleRow = (self._plan.modules or {})[scriptId]
	if not moduleRow then
		self._warn(string.format(
			"[scene_runtime] unknown script_id %q; skipping instance",
			tostring(scriptId)))
		return nil
	end
	local module_path = moduleRow.module_path
	local module_table = self._services.resolveModule(scriptId, module_path)
	if type(module_table) ~= "table" then
		self._warn(string.format(
			"[scene_runtime] module %s (path=%s) did not return a table",
			tostring(scriptId), tostring(module_path)))
		return nil
	end
	if type(module_table.new) ~= "function" then
		self._warn(string.format(
			"[scene_runtime] module %s missing new(config) constructor",
			tostring(scriptId)))
		return nil
	end
	local ok, instance = pcall(module_table.new, config or {})
	if not ok then
		self._warn(string.format(
			"[scene_runtime] %s.new threw: %s", tostring(scriptId), tostring(instance)))
		return nil
	end
	if type(instance) ~= "table" then
		self._warn(string.format(
			"[scene_runtime] %s.new returned non-table", tostring(scriptId)))
		return nil
	end
	-- Stash the class table so GetComponent / addComponent can identify
	-- the type without re-resolving the module.
	self:_register(instance, {
		scriptId = scriptId,
		stem = moduleRow.stem or scriptId,
		gameObjectId = gameObjectId,
		gameObjectInstance = gameObjectInstance,
		gameObjectName = gameObjectName,
		ownerKind = ownerKind,
		ownerRef = ownerRef,
		classTable = module_table,
		moduleRow = moduleRow,
		domain = moduleRow.domain,
		awakeCalled = false,
		startCalled = false,
		enableCalled = false,
		disableCalled = false,
	})
	return instance
end

function SceneRuntime:_computeActiveInHierarchyViaParentMap(goId)
	-- R5-P1.2: walk the parent map UP, AND-ing each ancestor's
	-- ``_goActiveSelf``. A GO absent from ``_goActiveSelf`` defaults to
	-- ``true`` (Unity's "no authored flag means active"); a GO absent
	-- from ``_goParentId`` is a planner-root -- the upward walk stops
	-- there. Cycle guard via depth budget: scene/prefab graphs are
	-- finite trees so a depth of 1024 vastly exceeds practical bounds
	-- and bails out cleanly on accidental cycles.
	local selfFlag = self._goActiveSelf[goId]
	if selfFlag == nil then selfFlag = true end
	if not selfFlag then return false end
	local cur = self._goParentId[goId]
	local depth = 0
	while cur ~= nil and depth < 1024 do
		local f = self._goActiveSelf[cur]
		if f == nil then f = true end
		if not f then return false end
		cur = self._goParentId[cur]
		depth = depth + 1
	end
	return true
end

function SceneRuntime:_injectHostSurface(instance, gameObjectInstance, gameObjectId)
	-- Surface bound BEFORE Awake, AFTER all new() per the design doc
	-- (lifecycle order steps 1->2->3). Constructor-purity rule (e) makes
	-- it safe to defer host wiring until after every new() returns.
	instance.gameObject = gameObjectInstance
	instance.transform = gameObjectInstance
	instance.instance = gameObjectInstance
	-- ``self.enabled`` is a per-component flag. Writes are intercepted
	-- via a metatable proxy so OnEnable/OnDisable fire on transitions.
	-- We track the underlying value in _meta so the metatable
	-- intercepts can do the gate work without a global key collision.
	-- IMPORTANT: planner-supplied ``active`` / ``enabled`` flags are
	-- copied into meta during _buildComponent's caller (step 1 of
	-- ``start``). Do NOT overwrite them here -- dormant components must
	-- stay dormant until ``setActive`` / ``setEnabled`` (or
	-- ``self.enabled = ...``) wakes them.
	local meta = self._meta[instance]
	if meta.enabled == nil then meta.enabled = true end
	if meta.activeSelf == nil then meta.activeSelf = true end
	-- R4-P1.2: project per-component ``activeSelf`` onto the per-GO
	-- ``_goActiveSelf`` map (single source of truth) and seed the
	-- computed ``activeInHierarchy`` with the same value. Boot has no
	-- ancestor info yet, so the initial gate equals the GO's own
	-- ``activeSelf``; the cascade re-derives it as soon as setActive
	-- runs. Multiple components on the same GO share the per-GO entry,
	-- so the LAST writer wins -- but the planner emits the same
	-- ``inst.active`` for every component on a GO, so this is a no-op.
	if gameObjectId then
		if self._goActiveSelf[gameObjectId] == nil then
			self._goActiveSelf[gameObjectId] = meta.activeSelf
		end
		-- R5-P1.2: compute the boot-time ``activeInHierarchy`` via the
		-- planner parent map so an authored-inactive ancestor's GO
		-- correctly suppresses descendants' boot-time ``OnEnable``.
		-- ``_computeActiveInHierarchyViaParentMap`` walks UP from
		-- ``gameObjectId``; the chain terminates at a GO whose
		-- ``_goParentId`` entry is missing (a planner-root). A GO with
		-- no entry yet defaults to ``activeSelf`` (the pre-R5
		-- behaviour) -- safe for ``addComponent``/dynamic instances
		-- whose parents the planner never saw.
		self._goActiveInHierarchy[gameObjectId] =
			self:_computeActiveInHierarchyViaParentMap(gameObjectId)
		meta.activeInHierarchy = self._goActiveInHierarchy[gameObjectId]
	else
		-- No id (e.g. addComponent on an unstamped instance): the
		-- gate degenerates to ``activeSelf`` so the existing
		-- single-component behaviour is preserved.
		meta.activeInHierarchy = meta.activeSelf
	end
	-- Remember GameObject Instance + id on meta so other services
	-- (instantiatePrefab reinjection, findGameObject) can rediscover
	-- the live Roblox instance.
	meta.gameObjectInstance = gameObjectInstance
	meta.gameObjectId = gameObjectId or meta.gameObjectId
	instance.host = self:_makeHostSurface(instance)

	-- Install a GetComponent(name) method on the instance. Resolution
	-- order: peer MonoBehaviour by stem -> Roblox built-in via
	-- ``findFirstChildWhichIsA`` on the GameObject. Built-in fallback
	-- preserves the design doc's "search by Roblox class" behaviour for
	-- ``Rigidbody``/``Collider``/``AudioSource``/``Animator``.
	local engine = self
	instance.GetComponent = function(_, name)
		-- Peer-component lookup first.
		local list = engine._componentsByGameObject[gameObjectId]
		if list then
			for _, comp in ipairs(list) do
				local m = engine._meta[comp]
				if m and (m.stem == name or m.scriptId == name) then
					return comp
				end
			end
		end
		-- Roblox built-in fallback. R4-P1.3: translate the Unity name
		-- to its Roblox equivalent before calling IsA/findFirstChildWhichIsA;
		-- Roblox's class hierarchy doesn't know names like "Rigidbody".
		if engine._services.findFirstChildWhichIsA then
			local mapped = _UNITY_TO_ROBLOX_CLASS[name]
			if mapped == _CLASS_TRANSFORM_SELF then
				-- Unity's Transform is intrinsic to every GameObject;
				-- the Roblox equivalent is the GameObject's root instance.
				return gameObjectInstance
			end
			-- ``mapped == nil`` -> fall through to the raw Unity name
			-- so unknown types preserve the pre-fix failure mode (and
			-- callers passing Roblox class names directly still work).
			local lookupName = mapped or name
			return engine._services.findFirstChildWhichIsA(gameObjectInstance, lookupName)
		end
		return nil
	end

	-- Per-instance ``self.enabled`` proxy. Writes to ``self.enabled``
	-- (rule-(c) / contract compliance) re-route through ``setEnabled``
	-- so ``OnEnable`` / ``OnDisable`` fire and host.connect subscriptions
	-- arm/disarm. Reads return the current gated value from meta.
	-- We install a per-instance metatable that wraps the original class
	-- metatable (preserves ``__index = Foo`` method lookup, ``__tostring``
	-- etc.) and intercepts only ``enabled``.
	local origMt = getmetatable(instance)
	-- Remove any pre-existing direct ``enabled`` so __newindex fires on
	-- subsequent writes. (Constructor-purity rule (e) means new() should
	-- not set it; we strip defensively.)
	rawset(instance, "enabled", nil)
	local newMt = {
		__index = function(t, k)
			if k == "enabled" then
				local m = engine._meta[t]
				return m and m.enabled
			end
			if origMt ~= nil then
				local idx = origMt.__index
				if type(idx) == "table" then return idx[k] end
				if type(idx) == "function" then return idx(t, k) end
			end
			return nil
		end,
		__newindex = function(t, k, v)
			if k == "enabled" then
				engine:setEnabled(t, v and true or false)
			else
				rawset(t, k, v)
			end
		end,
	}
	-- Preserve other commonly-used metamethods from the original class
	-- metatable (e.g. __tostring) without forwarding __index/__newindex.
	if type(origMt) == "table" then
		for k, v in pairs(origMt) do
			if k ~= "__index" and k ~= "__newindex" and newMt[k] == nil then
				newMt[k] = v
			end
		end
	end
	setmetatable(instance, newMt)
end

-- ---------------------------------------------------------------------
-- Reference wiring
-- ---------------------------------------------------------------------

function SceneRuntime:_resolveReferenceTarget(refRow, componentByInstanceId, placement_id)
	local target_kind = refRow.target_kind
	local target_ref = refRow.target_ref
	if target_kind == "component" then
		-- The engine union registry (``_componentByInstanceId``) is keyed by
		-- the PLACEMENT-SCOPED instance_id for prefab clones (``<placement>:
		-- <instance_id>``) so multiple placements of the same prefab don't
		-- collide (codex r3 BLOCKING). The per-owner LOCAL map is keyed by the
		-- raw ``instance_id``. Mirror the gameobject branch: when wiring inside
		-- a placement, try the namespaced key first (hits the engine map), then
		-- fall back to the raw key (hits the local map / scene-boot map, whose
		-- ids are already globally unique). A nil/empty placement_id is the
		-- scene-boot / harness path and resolves raw directly.
		if placement_id ~= nil and placement_id ~= "" then
			local ns_ref = placement_id .. ":" .. target_ref
			local hit = componentByInstanceId[ns_ref]
			if hit ~= nil then return hit end
		end
		return componentByInstanceId[target_ref]
	elseif target_kind == "gameobject" then
		-- Resolve to the Roblox Instance via _SceneRuntimeId attribute.
		-- Inside a prefab placement (``placement_id`` non-empty), every
		-- cloned descendant's SRI has been re-stamped to
		-- ``<placement>:<raw>`` so the workspace lookup must use the same
		-- namespace; the harness path (with no upfront re-stamp) falls
		-- back to the raw lookup. Codex round-3: without this branch the
		-- intra-prefab gameobject refs resolve to nil (production) or to
		-- the wrong placement's clone (when multiple placements share a
		-- raw SRI).
		if placement_id ~= nil and placement_id ~= "" then
			local ns_ref = placement_id .. ":" .. target_ref
			local hit = self._services.workspaceFind(ns_ref)
			if hit ~= nil then return hit end
		end
		return self._services.workspaceFind(target_ref)
	elseif target_kind == "prefab" then
		-- The host injects the stable prefab_id; modules pass it to
		-- ``instantiatePrefab``.
		return target_ref
	elseif target_kind == "scriptable_object" then
		-- R2-P1.3 contract: ``target_ref`` is the Unity GUID; the plan
		-- carries a ``scriptable_objects`` map (guid -> dotted DataModel
		-- module path) the host uses to resolve the live ModuleScript
		-- and ``require`` it. Pre-fix the runtime fed the raw GUID to
		-- ``resolveModule`` which tried to walk
		-- ``game:FindFirstChild(<guid>)`` -- always nil. Plans persisted
		-- before R2 won't carry the map; fall back to the legacy passthrough
		-- so the resolver still attempts the require (preserves the pre-R2
		-- failure mode rather than upgrading it to a hard crash).
		local so_map = (self._plan and self._plan.scriptable_objects) or {}
		local module_path = so_map[target_ref] or target_ref
		return self._services.resolveModule(target_ref, module_path)
	elseif target_kind == "asset" then
		-- R2-P1.3 contract: ``target_ref`` is ``rbxassetid://...`` after
		-- the pipeline's post-upload rewrite phase. Plans persisted before
		-- R2 may still carry raw Unity GUIDs; the host can't do anything
		-- useful with those, so they pass through and surface as broken
		-- asset refs (matching the pre-R2 behavior).
		return target_ref
	end
	return nil
end

function SceneRuntime:_assignFieldOnComponent(instance, field, index, value)
	-- Per the planner contract: ``index = nil`` means scalar field;
	-- ``index >= 0`` means array element. The planner emits 0-based
	-- indexes (Unity convention); we bridge to Lua's 1-based arrays
	-- with ``+1``. Treating ``index == 0`` as scalar would corrupt the
	-- first element of every serialized array ref.
	if index == nil then
		instance[field] = value
		return
	end
	local arr = instance[field]
	if type(arr) ~= "table" then
		arr = {}
		instance[field] = arr
	end
	arr[index + 1] = value
end

function SceneRuntime:_wireReferences(refs, componentByInstanceId,
                                       crossDomainEdges, instanceById,
                                       placement_id, targetResolveMap)
	-- ``targetResolveMap`` (optional): when wiring a deferred-UI group, a
	-- ``component``-kind ref's SOURCE must be in this group (gated by
	-- ``componentByInstanceId``, the group-built set), but its TARGET may be
	-- a SYNCHRONOUSLY-built peer or an earlier deferred group. Pass the
	-- engine-level union map here so those outbound refs resolve instead of
	-- silently staying nil (codex r2 BLOCKING -- the mirror of the inbound
	-- back-patch). nil (sync/prefab callers) => resolve targets against
	-- ``componentByInstanceId``, preserving prior behaviour.
	local resolveMap = targetResolveMap or componentByInstanceId
	-- ``instanceById`` is the planner's per-scene/prefab
	-- instance_id -> instance row map, used to resolve a target's
	-- ``script_id`` (and therefore its domain via plan.modules) even
	-- when the target component was never constructed in the current
	-- partition. Production entrypoints start ONE partition per
	-- process ("client" or "server"), so the opposite-side component
	-- never exists locally -- the cross-domain log + edge tracking
	-- must be plan-based, not registry-based.
	--
	-- ``placement_id`` (optional): when wiring references for an
	-- intra-prefab placement, the runtime has re-stamped every cloned
	-- descendant's ``_SceneRuntimeId`` to ``<placement>:<raw>``. Pass it
	-- through so ``gameobject`` ref lookups namespace their target_ref
	-- the same way -- otherwise the ref resolves to nil (or to a
	-- different placement's clone whose SRI happens to still be raw).
	local modules = self._plan.modules or {}
	for _, ref in ipairs(refs) do
		local sourceComp = componentByInstanceId[ref["from"]]
		if sourceComp ~= nil then
			local target = self:_resolveReferenceTarget(
				ref, resolveMap, placement_id)
			-- Cross-domain policy: if both source module and target
			-- module have assigned non-legacy domains and they differ,
			-- inject ``nil`` and surface the edge. Resolve via the plan
			-- so the policy fires even when the target isn't locally
			-- constructed (real boots only run one partition).
			if ref.target_kind == "component" then
				local srcMeta = self._meta[sourceComp]
				local tgtRow = instanceById and instanceById[ref.target_ref]
				local tgtDomain
				local tgtScriptId
				if tgtRow then
					tgtScriptId = tgtRow.script_id
					local tgtModule = modules[tgtScriptId]
					tgtDomain = tgtModule and tgtModule.domain
				end
				if srcMeta and srcMeta.domain and tgtDomain
				   and srcMeta.domain ~= "legacy"
				   and srcMeta.domain ~= "excluded"
				   and srcMeta.domain ~= "helper"
				   and tgtDomain ~= "legacy"
				   and tgtDomain ~= "excluded"
				   and tgtDomain ~= "helper"
				   and srcMeta.domain ~= tgtDomain then
					self._warn(string.format(
						"[scene_runtime] cross-domain ref %s(%s).%s -> %s(%s) -> injecting nil",
						srcMeta.scriptId, srcMeta.domain, ref.field,
						tostring(tgtScriptId), tgtDomain))
					target = nil
					if crossDomainEdges then
						table.insert(crossDomainEdges, {
							from_script = srcMeta.scriptId,
							to_script = tgtScriptId,
							field = ref.field,
							from_domain = srcMeta.domain,
							to_domain = tgtDomain,
						})
					end
				end
			end
			-- Slice 1.1 r1: back-patch bookkeeping. When a component-kind ref
			-- targets an instance that was DEFERRED (its UI host clone hadn't
			-- landed, so it wasn't built in this synchronous pass), the
			-- resolve above yields nil. Record the (source, field, index,
			-- target_instance_id) so ``_completeDeferredBatch`` can set the
			-- field once the deferred target is built. Only when this wiring
			-- pass is the synchronous boot (target genuinely absent + known
			-- deferred) -- the deferred batch's own re-wire passes a present
			-- map so this branch is skipped.
			if ref.target_kind == "component" and target == nil then
				-- The deferred-id set + back-patch records use the PLACEMENT-
				-- SCOPED target key (codex r3 BLOCKING) so a multi-placed
				-- deferred prefab's inbound refs bind to the correct placement.
				-- ``ref.target_ref`` is the raw prefab-local id within THIS
				-- placement; scope it with the wiring pass's placement_id.
				local scopedTarget = ref.target_ref
				if placement_id ~= nil and placement_id ~= "" then
					scopedTarget = placement_id .. ":" .. ref.target_ref
				end
				if self._deferredInstanceIds
				   and self._deferredInstanceIds[scopedTarget] then
					self._inboundRefsToDeferred = self._inboundRefsToDeferred or {}
					table.insert(self._inboundRefsToDeferred, {
						source = sourceComp,
						field = ref.field,
						index = ref.index,
						target_ref = scopedTarget,
					})
				end
			end
			self:_assignFieldOnComponent(sourceComp, ref.field, ref.index, target)
		end
	end
end

-- ---------------------------------------------------------------------
-- Lifecycle (deterministic order from the design doc)
-- ---------------------------------------------------------------------

function SceneRuntime:_callMethod(instance, name, ...)
	local class = self._meta[instance].classTable
	local fn = class and class[name]
	if type(fn) == "function" then
		local ok, err = pcall(fn, instance, ...)
		if not ok then
			self._warn(string.format(
				"[scene_runtime] %s.%s threw: %s",
				tostring(self._meta[instance].scriptId), name, tostring(err)))
		end
	end
end

function SceneRuntime:_runAwakeEnableStart(instances)
	-- Step 3: Awake (in lifecycle_order; constructors already ran in
	-- step 1 + refs were wired in step 2).
	for _, comp in ipairs(instances) do
		local m = self._meta[comp]
		if m and not m.awakeCalled then
			m.awakeCalled = true
			self:_callMethod(comp, "Awake")
		end
	end
	-- Step 4: OnEnable (only active + enabled). R4-P1.2: gate on the
	-- computed ``activeInHierarchy`` so an ancestor's authored-inactive
	-- flag suspends descendants even at boot.
	for _, comp in ipairs(instances) do
		local m = self._meta[comp]
		if m and m.activeInHierarchy and m.enabled and not m.enableCalled then
			m.enableCalled = true
			m.disableCalled = false
			-- Rearm any host.connect subscriptions for this comp.
			self:_rearmSubs(comp)
			self:_callMethod(comp, "OnEnable")
		end
	end
	-- Step 5: Start on next tick (only for components booted active + enabled;
	-- dormant components Start on first false->true gate transition via
	-- ``_scheduleStartIfPending``).
	self:_scheduleStartIfPending(instances)
end

function SceneRuntime:_scheduleStartIfPending(instances)
	-- Defer Start to next tick per the Unity lifecycle contract.
	-- ``instances`` may be a single-element list (called from
	-- setEnabled/setActive after a late re-enable) or the full batch
	-- (initial boot). Only components currently in the active+enabled gate
	-- that haven't fired Start yet are queued; ``_startFired`` flips to
	-- true once Start runs so subsequent gate transitions are no-ops.
	local engine = self
	self._services.task.defer(function()
		for _, comp in ipairs(instances) do
			local m = engine._meta[comp]
			if m and not m.startCalled and m.activeInHierarchy and m.enabled then
				m.startCalled = true
				engine:_callMethod(comp, "Start")
			end
		end
	end)
end

-- ---------------------------------------------------------------------
-- Lifecycle-scoped event wiring (host.connect)
-- ---------------------------------------------------------------------

function SceneRuntime:_isGateOpen(comp)
	-- R4-P1.2: dispatch gate is ``activeInHierarchy AND enabled`` so
	-- ancestor-disabled descendants don't fire callbacks even when
	-- their own ``activeSelf`` is true.
	local m = self._meta[comp]
	if not m then return false end
	return m.activeInHierarchy and m.enabled
end

function SceneRuntime:_rearmSubs(comp)
	local subs = self._subs[comp]
	if not subs then return end
	for _, sub in ipairs(subs) do
		if sub.conn == nil and self:_isGateOpen(comp) then
			-- ``signal:Connect`` per Roblox API.
			sub.conn = sub.signal:Connect(function(...)
				if self:_isGateOpen(comp) then
					sub.fn(...)
				end
			end)
		end
	end
end

function SceneRuntime:_disarmSubs(comp)
	local subs = self._subs[comp]
	if not subs then return end
	for _, sub in ipairs(subs) do
		if sub.conn then
			sub.conn:Disconnect()
			sub.conn = nil
		end
	end
end

function SceneRuntime:connect(comp, signal, fn)
	assert(type(fn) == "function", "host.connect: fn must be function")
	assert(signal ~= nil, "host.connect: signal required")
	local list = self._subs[comp]
	if not list then list = {}; self._subs[comp] = list end
	local entry = { signal = signal, fn = fn, conn = nil }
	table.insert(list, entry)
	if self:_isGateOpen(comp) then
		entry.conn = signal:Connect(function(...)
			if self:_isGateOpen(comp) then
				fn(...)
			end
		end)
	end
	-- Return a handle the caller can ignore. Disconnect is owned by
	-- the engine; raw Disconnect would desync the subs table.
	return entry
end

-- ---------------------------------------------------------------------
-- Lifecycle-scoped scheduler
-- ---------------------------------------------------------------------

function SceneRuntime:_trackTask(comp, handle)
	local list = self._tasks[comp]
	if not list then list = {}; self._tasks[comp] = list end
	table.insert(list, handle)
end

function SceneRuntime:_cancelAllTasks(comp)
	local list = self._tasks[comp]
	if not list then return end
	for _, entry in ipairs(list) do
		-- ``invoke`` / ``invokeRepeating`` overwrite the raw thread with
		-- a ``{handle=, method=, repeating?=}`` wrapper table (so
		-- ``cancelInvoke`` can find handles by method label). Roblox's
		-- ``task.cancel`` expects the raw thread/handle, NOT a table --
		-- pcall would silently swallow the failure and the repeating
		-- task would keep firing. Unwrap here the same way
		-- ``cancelInvoke`` already does.
		local h = (type(entry) == "table" and entry.handle) or entry
		if self._services.task.cancel then
			pcall(self._services.task.cancel, h)
		end
	end
	self._tasks[comp] = nil
end

function SceneRuntime:invoke(comp, method, delay)
	local engine = self
	local handle
	handle = self._services.task.delay(delay, function()
		if engine._destroyed[comp] then return end
		local m = engine._meta[comp]
		if not m then return end
		local fn = (m.classTable or {})[method]
		if type(fn) == "function" then
			pcall(fn, comp)
		end
	end)
	self:_trackTask(comp, handle)
	-- Stash the method label so ``cancelInvoke`` can target by method.
	self._tasks[comp][#self._tasks[comp]] = {handle = handle, method = method}
	return handle
end

function SceneRuntime:invokeRepeating(comp, method, delay, every)
	local engine = self
	local handle
	handle = self._services.task.delay(delay, function()
		while not engine._destroyed[comp] do
			local m = engine._meta[comp]
			if not m then return end
			local fn = (m.classTable or {})[method]
			if type(fn) == "function" then
				pcall(fn, comp)
			end
			engine._services.task.wait(every)
		end
	end)
	self:_trackTask(comp, handle)
	self._tasks[comp][#self._tasks[comp]] = {handle = handle, method = method, repeating = true}
	return handle
end

function SceneRuntime:cancelInvoke(comp, method)
	local list = self._tasks[comp]
	if not list then return end
	for i = #list, 1, -1 do
		local entry = list[i]
		if (not method) or (type(entry) == "table" and entry.method == method) then
			local h = (type(entry) == "table" and entry.handle) or entry
			if self._services.task.cancel then
				pcall(self._services.task.cancel, h)
			end
			table.remove(list, i)
		end
	end
end

function SceneRuntime:startCoroutine(comp, fn)
	local engine = self
	local handle = self._services.task.spawn(function()
		if engine._destroyed[comp] then return end
		pcall(fn, comp)
	end)
	self:_trackTask(comp, handle)
	return handle
end

-- ---------------------------------------------------------------------
-- Global lookup registry
-- ---------------------------------------------------------------------

function SceneRuntime:findObjectOfType(name)
	local list = self._byClass[name]
	if list and list[1] then return list[1] end
	return nil
end

function SceneRuntime:findGameObject(name)
	local list = self._byName[name]
	if list and list[1] then return list[1] end
	return nil
end

function SceneRuntime:findGameObjectsWithTag(tag)
	local list = self._byTag[tag]
	if not list then return {} end
	-- Return a copy so caller mutation doesn't break the registry.
	local out = {}
	for i, c in ipairs(list) do out[i] = c end
	return out
end

-- ---------------------------------------------------------------------
-- Active / enabled toggles
-- ---------------------------------------------------------------------

function SceneRuntime:_applyActiveToComponent(comp, inHierarchy, pendingStarts)
	-- R4-P1.2: ``inHierarchy`` is the GO's NEW computed
	-- ``activeInHierarchy`` (NOT the raw setActive arg). The caller
	-- (``setActive``) walks the subtree top-down, computing each GO's
	-- gate as ``goActiveSelf[id] AND goActiveInHierarchy[parent]`` and
	-- feeds the resolved gate here. Per-component ``activeSelf`` stays
	-- untouched -- only a direct ``setActive(go=THIS, ...)`` mutates it
	-- (via the caller updating ``_goActiveSelf`` for the root id).
	local m = self._meta[comp]
	if not m then return end
	local was = m.activeInHierarchy and m.enabled
	m.activeInHierarchy = inHierarchy and true or false
	local now = m.activeInHierarchy and m.enabled
	if was and not now then
		m.disableCalled = true
		m.enableCalled = false
		self:_disarmSubs(comp)
		self:_callMethod(comp, "OnDisable")
	elseif (not was) and now then
		m.enableCalled = true
		m.disableCalled = false
		self:_rearmSubs(comp)
		self:_callMethod(comp, "OnEnable")
		-- Late re-enable: Unity fires Start on the FIRST transition to
		-- active+enabled. If the component never satisfied that gate at
		-- boot (dormant: active=false or enabled=false), queue Start now.
		if not m.startCalled and pendingStarts ~= nil then
			table.insert(pendingStarts, comp)
		end
	end
end

function SceneRuntime:applyImpulse(part, force)
	-- Phase 1 (relation #8): apply the faithful stud-scaled launch velocity for a force-launched
	-- body, independent of the STUDS_PER_METER³-inflated Roblox mass:
	--     Δv = (force / m_unity) * STUDS_PER_METER     (mass-agnostic: the wrong m_rbx cancels)
	-- where m_unity is the convert-time ``_UnityMass`` stamp, resolved at the ASSEMBLY level so a
	-- wrapped Model (outer Model + inner ``*_Mesh``) or a ``TriggerZone`` sibling still launches the
	-- right body with the right mass.
	-- Guard the PART arg (the body we resolve + correct): check indexability (table/userdata) BEFORE
	-- ``_isBasePart`` (which indexes ``inst.IsA``) so a bare number/string never hard-errors. ``force``
	-- is the AI's Vector3 argument passed straight through — a malformed force errors exactly as
	-- today's raw ``part:ApplyImpulse(force)`` would (never worse), and is NOT silently swallowed
	-- (a no-op would mask an AI codegen bug).
	if (type(part) ~= "table" and type(part) ~= "userdata") or not _isBasePart(part) then
		return
	end
	local target, mUnity = part, part:GetAttribute("_UnityMass")
	if mUnity == nil and part.AssemblyRootPart then
		target = part.AssemblyRootPart
		mUnity = target:GetAttribute("_UnityMass")
	end
	if mUnity == nil then
		local owner = part:FindFirstAncestorWhichIsA("Model")
		if owner then
			for _, d in ipairs(owner:GetDescendants()) do
				if d:IsA("BasePart") and d:GetAttribute("_UnityMass") ~= nil then
					target, mUnity = d, d:GetAttribute("_UnityMass")
					break
				end
			end
		end
	end
	if mUnity ~= nil and mUnity > 0 then
		target.AssemblyLinearVelocity = target.AssemblyLinearVelocity
			+ (force / mUnity) * STUDS_PER_METER
	else
		-- Unstamped (non-dynamic / missing): fall back to the raw impulse — never worse than today.
		part:ApplyImpulse(force)
	end
end

function SceneRuntime:setActive(go, bool)
	-- R4-P1.2: split ``activeSelf`` (per-GO authored) from
	-- ``activeInHierarchy`` (per-GO computed = self AND ancestor chain).
	-- The previous cascade overwrote every descendant's stored
	-- ``activeSelf`` to the toggled value, so a child authored
	-- ``activeSelf == false`` wrongly re-activated when its parent
	-- toggled back on. Fix: only mutate ``_goActiveSelf`` for the
	-- TOGGLED GO; walk the subtree top-down recomputing each
	-- descendant's ``activeInHierarchy`` as
	-- ``_goActiveSelf[id] AND _goActiveInHierarchy[parent(id)]``.
	-- ``go`` may be either a Roblox Instance or a game_object_id string.
	local goId
	local goInst
	if type(go) == "string" then
		goId = go
	elseif type(go) == "table" then
		goInst = go
		if self._services.getInstanceId then
			goId = self._services.getInstanceId(go)
		end
	else
		return
	end
	if not goId then return end

	-- The toggled GO's own activeSelf moves; the in-hierarchy gate is
	-- AND-ed with whatever its ancestor chain already evaluates to.
	-- We treat the toggled GO's CURRENT activeInHierarchy minus its
	-- OWN self contribution as the inherited ancestor gate, then
	-- re-AND with the new value. Concretely:
	--   ancestorGate = (old_activeInHierarchy[goId]) OR (old_activeSelf[goId])
	--                  evaluated such that ancestorGate := old gate WITHOUT self
	-- The clean computation is: ancestorGate = (oldInHierarchy == oldSelf)?
	-- That's circular. Simpler: maintain the invariant
	--   activeInHierarchy[goId] == activeSelf[goId] AND ancestorGate
	-- and never lose track of ancestorGate. We don't have a parent map
	-- at the GO layer, but we DO have the invariant: if the toggled GO
	-- is currently in hierarchy, its ancestorGate is true; if not, its
	-- ancestorGate equals activeSelf[goId] == false but the ancestor
	-- could be either true or false. Without an ancestor map we'd
	-- regress on a child toggling itself while a parent is also
	-- inactive. Practical fix: track ancestorGate per GO explicitly via
	-- the optional service ``collectSubtreeIdsWithParents`` -- when
	-- provided we get full top-down parent info. When not provided we
	-- degrade to the legacy single-id behavior (the R2 cascade was an
	-- improvement over no cascade, and the new behavior is strictly
	-- better with the new service).
	local pendingStarts = {}

	-- Update the toggled GO's authored flag.
	self._goActiveSelf[goId] = bool and true or false

	local function applyComponentsAt(id)
		local list = self._componentsByGameObject[id]
		if not list then return end
		-- Snapshot so per-component state mutations don't disturb iteration.
		local snap = {}
		for i, c in ipairs(list) do snap[i] = c end
		local hierarchy = self._goActiveInHierarchy[id]
		for _, comp in ipairs(snap) do
			self:_applyActiveToComponent(comp, hierarchy, pendingStarts)
		end
	end

	local svc = self._services
	-- R5-P1.2: the toggled GO's ancestor gate ("is every ancestor's
	-- activeSelf true?") is the AND over the planner parent map walked
	-- UP from ``goId``. ``collectSubtreeIdsWithParents`` only gives us
	-- the DOWNWARD tree from ``goId`` -- the walked root has no parentId
	-- entry in that list -- so we need the planner map to know whether
	-- a higher ancestor is inactive.
	local toggledAncestorGate = true
	do
		local cur = self._goParentId[goId]
		local depth = 0
		while cur ~= nil and depth < 1024 do
			local f = self._goActiveSelf[cur]
			if f == nil then f = true end
			if not f then toggledAncestorGate = false; break end
			cur = self._goParentId[cur]
			depth = depth + 1
		end
	end
	if goInst ~= nil and svc.collectSubtreeIdsWithParents then
		-- DFS preorder: root first, then descendants with parentId.
		-- Each entry: {id = "...", parentId = "..."} (root's parentId is nil).
		local entries = svc.collectSubtreeIdsWithParents(goInst)
		for _, e in ipairs(entries) do
			local id = e.id
			local parentId = e.parentId
			local selfFlag = self._goActiveSelf[id]
			if selfFlag == nil then selfFlag = true end
			local parentHier
			if parentId == nil then
				-- Root of the walk. For the toggled GO use the
				-- planner-derived ancestor gate so an inactive
				-- grandparent suppresses the toggle until the
				-- grandparent re-enables (matches Unity). For other
				-- roots (defensive: should only be one root) use the
				-- previously-stored in-hierarchy if any, else default
				-- to true.
				if id == goId then
					parentHier = toggledAncestorGate
				else
					parentHier = self._goActiveInHierarchy[id]
					if parentHier == nil then parentHier = true end
				end
			else
				parentHier = self._goActiveInHierarchy[parentId]
				if parentHier == nil then parentHier = true end
			end
			local newHier = selfFlag and parentHier and true or false
			self._goActiveInHierarchy[id] = newHier
			applyComponentsAt(id)
		end
	elseif goInst ~= nil and svc.collectDescendantIds then
		-- Backward-compat path (no Roblox-tree parent map service): the
		-- toggled GO's ``activeSelf`` was just updated; descendants
		-- recompute their gate as ``descendantSelf AND toggledGoInHier``.
		-- R5-P1.2: the toggled GO's own gate is ``activeSelf AND
		-- toggledAncestorGate`` (planner ancestor walk), not just
		-- ``activeSelf`` -- an inactive grandparent still suppresses.
		local ids = svc.collectDescendantIds(goInst)
		-- DFS post-order: parents emit last. Update root's hierarchy
		-- first then descendants.
		local rootSelf = self._goActiveSelf[goId]
		if rootSelf == nil then rootSelf = true end
		local rootHier = rootSelf and toggledAncestorGate and true or false
		self._goActiveInHierarchy[goId] = rootHier
		applyComponentsAt(goId)
		for _, id in ipairs(ids) do
			if id ~= goId then
				local selfFlag = self._goActiveSelf[id]
				if selfFlag == nil then selfFlag = true end
				self._goActiveInHierarchy[id] = selfFlag and rootHier and true or false
				applyComponentsAt(id)
			end
		end
	else
		-- No subtree info: only toggle the root. R5-P1.2: still AND in
		-- the planner ancestor gate so a setActive on a deeply-nested GO
		-- can't bypass an inactive ancestor.
		local rootSelf = self._goActiveSelf[goId]
		if rootSelf == nil then rootSelf = true end
		self._goActiveInHierarchy[goId] = rootSelf and toggledAncestorGate and true or false
		applyComponentsAt(goId)
	end

	if #pendingStarts > 0 then
		self:_scheduleStartIfPending(pendingStarts)
	end
end

function SceneRuntime:setEnabled(comp, bool)
	-- R4-P1.2: gate on ``activeInHierarchy`` (the computed effective
	-- gate). Toggling ``enabled`` doesn't touch the GO's authored
	-- ``activeSelf`` or its ancestor chain, so we only check the
	-- combined gate against the new ``enabled`` value.
	local m = self._meta[comp]
	if not m then return end
	local was = m.activeInHierarchy and m.enabled
	m.enabled = bool and true or false
	local now = m.activeInHierarchy and m.enabled
	if was and not now then
		m.disableCalled = true
		m.enableCalled = false
		self:_disarmSubs(comp)
		self:_callMethod(comp, "OnDisable")
	elseif (not was) and now then
		m.enableCalled = true
		m.disableCalled = false
		self:_rearmSubs(comp)
		self:_callMethod(comp, "OnEnable")
		-- Late re-enable: Unity fires Start on the FIRST transition to
		-- active+enabled. Defer Start when this is the first time the
		-- component has been active+enabled.
		if not m.startCalled then
			self:_scheduleStartIfPending({comp})
		end
	end
end

-- ---------------------------------------------------------------------
-- Recursive destroy
-- ---------------------------------------------------------------------

function SceneRuntime:_destroyComponent(comp)
	if self._destroyed[comp] then return end
	self._destroyed[comp] = true
	self:_cancelAllTasks(comp)
	self:_disarmSubs(comp)
	self._subs[comp] = nil

	local m = self._meta[comp]
	if m then
		-- Contract: BOTH ``OnDisable`` and ``OnDestroy`` are
		-- guaranteed-once and skipped if ``OnEnable`` never ran. A
		-- boot-dormant component that never satisfied the
		-- active+enabled gate is torn down silently (no Awake-only
		-- callbacks). R3-P1.2: previously OnDestroy fired whenever
		-- Awake ran, violating the contract for dormant components.
		local everEnabled = m.enableCalled or m.disableCalled
		if m.enableCalled and not m.disableCalled then
			m.disableCalled = true
			self:_callMethod(comp, "OnDisable")
		end
		if m.awakeCalled and everEnabled then
			self:_callMethod(comp, "OnDestroy")
		end
	end
	self:_unregister(comp)
end

function SceneRuntime:destroy(target)
	-- DFS: collect components in the subtree by game-object id, walk
	-- deepest-first.
	-- Two input shapes:
	--   - Roblox Instance: collect IDs via _SceneRuntimeId attribute.
	--   - Component instance directly.
	if self._meta[target] then
		-- Single component case.
		self:_destroyComponent(target)
		return
	end
	-- Otherwise target is a Roblox Instance (userdata in real Luau; the test
	-- harness substitutes a table). ``type()`` distinguishes those: live
	-- Roblox Models are ``"userdata"`` not ``"table"``, so the old guard
	-- ``type(target) ~= "table"`` early-returned on EVERY real Instance,
	-- silently turning ``host.destroy(self.gameObject)`` into a no-op for
	-- e.g. ``Pickup``'s on-touch cleanup. Accept either shape; reject only
	-- primitives / nil where the descendant walk has nothing to chew on.
	local t = type(target)
	if t ~= "table" and t ~= "userdata" then return end
	-- Walk the Roblox instance tree deepest-first via the services.
	if self._services.collectDescendantIds then
		local ids = self._services.collectDescendantIds(target)
		-- ids is a list of game_object_id strings, deepest first.
		for _, goId in ipairs(ids) do
			local comps = self._componentsByGameObject[goId]
			if comps then
				-- Iterate over a snapshot since _destroyComponent
				-- unregisters from the same table.
				local snap = {}
				for i, c in ipairs(comps) do snap[i] = c end
				for _, comp in ipairs(snap) do
					self:_destroyComponent(comp)
				end
			end
		end
	end
	-- Track the prefab clone so a subsequent destroy() is idempotent.
	self._prefabClones[target] = nil
	if self._services.destroyInstance then
		pcall(self._services.destroyInstance, target)
	end
end

-- ---------------------------------------------------------------------
-- Dynamic component creation
-- ---------------------------------------------------------------------

function SceneRuntime:addComponent(go, scriptId, config)
	local goId
	local goName = ""
	if type(go) == "string" then
		goId = go
	elseif type(go) == "table" then
		if self._services.getInstanceId then
			goId = self._services.getInstanceId(go)
		end
		goName = (type(go) == "table" and go.Name) or ""
	end
	if not goId then return nil end
	local comp = self:_buildComponent(scriptId, go, goId, goName, config, "runtime", "")
	if not comp then return nil end
	self:_injectHostSurface(comp, go, goId)
	-- Single-instance variants of the lifecycle.
	self:_runAwakeEnableStart({comp})
	return comp
end

-- ---------------------------------------------------------------------
-- Prefab instantiation
-- ---------------------------------------------------------------------

-- Construct (but do NOT run the lifecycle for) the components of a prefab
-- subplan against a live ``clone`` root. Shared by ``instantiatePrefab``
-- (runtime script-triggered spawn) and ``start()``'s pre-placed-placement
-- boot (Bug B tier 1). Returns the constructed ``componentList`` ready to
-- hand to ``_runAwakeEnableStart``; the caller owns the lifecycle batch so
-- placement boots can append to the global Awake/OnEnable/Start ordering.
--
-- ``includeScriptId`` (optional): when a table, only instances whose
-- ``script_id`` is a key are constructed (domain filtering for the boot
-- path). When nil, every instance is constructed — ``instantiatePrefab``'s
-- original unfiltered behavior (a runtime spawn isn't domain-gated).
--
-- ``externalRefs`` (optional): caller-supplied per-instance field overrides
-- applied after intra-prefab references wire (``instantiatePrefab`` only).
--
-- ``clone`` resolution: when a clone root Instance is supplied
-- (``instantiatePrefab``), prefab-local GameObject ids resolve via
-- ``resolveCloneChild(clone, id)`` scoped under that clone. When ``clone``
-- is nil (``start()``'s pre-placed-placement boot, Bug B tier 1), the
-- placement clone already lives in the live tree stamped with its
-- prefab-local ``_SceneRuntimeId``s, so ids resolve via ``workspaceFind`` —
-- the same global lookup the scene boot path uses. For a SINGLE placement
-- this returns the one correct clone descendant (duplicate-placement
-- identity is tier 2).
-- Compose a placement-scoped GameObject id from a prefab-local one.
-- Returns ``placement_id .. ":" .. goid`` when both are present and non-empty;
-- otherwise returns ``goid`` unchanged. Centralised so every read AND write
-- site agrees on the encoding (the round-1 fix only namespaced writes and
-- left ``setActive`` / ``destroy`` to look up by the raw goid, silently
-- no-opping on multi-placement clones -- Codex P1 round 2).
local function _idWithPlacement(placement_id, goid)
	if placement_id ~= nil and placement_id ~= "" and goid ~= nil then
		return placement_id .. ":" .. goid
	end
	return goid
end

function SceneRuntime:_constructPrefabClone(clone, prefab, prefab_id, includeScriptId, externalRefs, placement_id, deferUiMisses)
	-- ``deferUiMisses`` (optional, default false): when true, a UI-owned
	-- instance whose host lookup misses is DEFERRED to event-driven PlayerGui
	-- resolution (the scene/prefab BOOT path, which races the
	-- StarterGui->PlayerGui clone). The runtime-spawn path
	-- (``instantiatePrefab``) leaves it false: a runtime-spawned prefab
	-- resolves its UI host against the LOCAL clone via ``resolveCloneChild``
	-- (no PlayerGui boot race), so deferral is the wrong tool -- waiting on
	-- ``PlayerGui.DescendantAdded`` would never fire for a host under the
	-- clone and the component would silently drop. With it false the UI miss
	-- falls through to the one-shot build (pre-slice behaviour).
	-- Build a per-instance map for the prefab subplan; references are
	-- prefab-local so the same logic applies as for scenes.
	--
	-- ``placement_id`` namespaces every prefab-local game_object_id used
	-- in this construction. The Roblox lookup goes by the prefab-local
	-- (un-namespaced) id BEFORE stamping -- after we find the live clone
	-- descendant, we SetAttribute its ``_SceneRuntimeId`` to the
	-- namespaced id so the runtime's read paths (``getInstanceId`` ->
	-- ``_componentsByGameObject`` / ``_goActiveSelf`` / ``_goParentId``)
	-- all agree on this clone's identity. The next placement's iteration
	-- of the SAME prefab_id then sees the previous clone's attribute
	-- mismatch and skips it, binding to a different workspace clone.
	-- A nil/empty placement_id is a no-op for stamping -- preserves
	-- legacy single-placement / harness behaviour.
	local componentByInstanceId = {}
	local componentList = {}
	local instanceById = {}

	-- UPFRONT walk: re-stamp every cloned descendant whose ``_SceneRuntimeId``
	-- starts with this prefab's namespace (``<prefab_id>:``) so the final
	-- attribute reads ``<placement_id>:<old_sri>``. This covers BOTH MB-
	-- bearing hosts (which the per-component loop revisits) and unscripted
	-- ancestors / non-MB descendants that the loop never sees. Skipping the
	-- non-MB nodes (the round-2 round-1 design) left the parent map keyed
	-- on ``<placement>:child -> <placement>:root`` while ``root``'s
	-- ``_SceneRuntimeId`` stayed raw, so ``setActive(root, false)`` wrote
	-- to the wrong key and ``setActive(child, true)`` cascade missed the
	-- inactive ancestor (Codex R3). One walk per placement, before the
	-- per-component loop, means every later lookup (here AND in
	-- ``_wireReferences``) sees a consistently namespaced view.
	local function _stamp_descendants_upfront()
		if clone == nil or placement_id == nil or placement_id == ""
		   or prefab_id == nil or prefab_id == "" then
			return
		end
		local prefix = prefab_id .. ":"
		-- ``clone`` may be a MID-level prefab node: the planner only emits
		-- MB-bearing rows in ``prefab.instances``, so when no MonoBehaviour
		-- sits at the authored prefab root, ``_findUnboundClonePerPrefab``
		-- resolves to a descendant (the first one that DOES carry an MB).
		-- Walk UP via ``.Parent`` while the parent's _SceneRuntimeId still
		-- carries this prefab's namespace -- that ancestor IS part of the
		-- placement and must be stamped or its raw SRI keeps aliasing
		-- across placements (Codex R4: ``setActive(Root, false)`` on the
		-- unscripted root writes to the shared raw key and the cascade
		-- through ``<placement>:child -> <placement>:root`` misses it).
		-- 128 is a generous depth budget for any realistic prefab.
		local root = clone
		local depth = 0
		while depth < 128 do
			local p_ok, parent = pcall(function() return root.Parent end)
			if not p_ok or parent == nil then break end
			local sri_ok, parent_sri = pcall(function()
				return parent:GetAttribute("_SceneRuntimeId")
			end)
			if not sri_ok or type(parent_sri) ~= "string"
			   or string.sub(parent_sri, 1, #prefix) ~= prefix then
				break
			end
			root = parent
			depth = depth + 1
		end
		local function _rewrite(node)
			local sri_ok, sri = pcall(function()
				return node:GetAttribute("_SceneRuntimeId")
			end)
			if sri_ok and type(sri) == "string"
			   and string.sub(sri, 1, #prefix) == prefix then
				pcall(function()
					node:SetAttribute("_SceneRuntimeId",
						placement_id .. ":" .. sri)
				end)
			end
		end
		_rewrite(root)
		local ok, descs = pcall(function() return root:GetDescendants() end)
		if ok and type(descs) == "table" then
			for _, d in ipairs(descs) do
				_rewrite(d)
			end
		end
	end
	_stamp_descendants_upfront()

	-- Cache prefab-local goid -> live Instance: a prefab GameObject can host
	-- MULTIPLE MonoBehaviours, so the same ``inst.game_object_id`` appears
	-- multiple times in ``prefab.instances``. Looking up (and especially
	-- stamping) more than once would either bind later rows to the wrong
	-- Instance (round-2 bug) or leave them with ``nil`` gameObject.
	local goInstByGoid = {}
	for _, inst in ipairs(prefab.instances or {}) do
		instanceById[inst.instance_id] = inst
		if (includeScriptId == nil) or includeScriptId[inst.script_id] then
			local ns_goid = _idWithPlacement(placement_id, inst.game_object_id)
			-- Resolve the live Roblox child. Try NS first: production
			-- placements have their cloned descendants' SRIs already re-
			-- stamped namespaced by the upfront walk, so the ns lookup is
			-- the universal production hit. Fall back to the RAW id for
			-- the harness path (synthetic clone without ``GetDescendants``,
			-- so the upfront walk was a no-op and the SRI is still raw).
			-- ``resolveCloneChild`` returns nil on miss (the prior sentinel-
			-- on-miss behaviour was changed in R3 because it made this
			-- fallback ambiguous).
			local goInst = goInstByGoid[inst.game_object_id]
			if goInst == nil then
				if clone ~= nil then
					if ns_goid ~= inst.game_object_id then
						goInst = self._services.resolveCloneChild(clone, ns_goid)
					end
					if goInst == nil then
						goInst = self._services.resolveCloneChild(
							clone, inst.game_object_id)
					end
				else
					if ns_goid ~= inst.game_object_id then
						goInst = self._services.workspaceFind(ns_goid)
					end
					if goInst == nil then
						goInst = self._services.workspaceFind(inst.game_object_id)
					end
				end
				goInstByGoid[inst.game_object_id] = goInst
				-- Best-effort per-instance stamp for the harness path or
				-- any Instance whose SRI the upfront walk did not touch
				-- (e.g. found via raw fallback after the walk missed). A
				-- second SetAttribute on an already-namespaced attribute
				-- is harmless because the upfront walk only rewrites
				-- prefab-prefix-matching SRIs.
				if goInst ~= nil and placement_id ~= nil and placement_id ~= ""
				   and ns_goid ~= inst.game_object_id then
					local sri_ok, cur = pcall(function()
						return goInst:GetAttribute("_SceneRuntimeId")
					end)
					if not sri_ok or cur ~= ns_goid then
						pcall(function()
							goInst:SetAttribute("_SceneRuntimeId", ns_goid)
						end)
					end
				end
			end
			-- Slice 1.1: a UI-owned prefab instance whose host lookup missed
			-- defers to event-driven PlayerGui resolution, identical to the
			-- scene-boot path. Non-UI misses keep the one-shot behaviour.
			if goInst == nil and deferUiMisses and self:_isUiOwned(inst) then
				self:_deferUiInstance({
					inst = inst,
					gameObjectId = ns_goid,
					ownerKind = "prefab",
					ownerRef = prefab_id,
					references = prefab.references or {},
					byInstanceId = instanceById,
					placement_id = placement_id,
					externalRefs = externalRefs,
				})
			else
				local comp = self:_buildComponent(
					inst.script_id, goInst, ns_goid,
					(goInst and goInst.Name) or "", inst.config or {},
					"prefab", prefab_id)
				if comp then
					componentByInstanceId[inst.instance_id] = comp
					-- Engine union key is PLACEMENT-SCOPED (codex r3 BLOCKING):
					-- ``inst.instance_id`` is prefab-LOCAL (``<prefab>:<file>``)
					-- and shared by every placement of the prefab, so an
					-- un-namespaced engine key let the last placement overwrite
					-- the others and the deferred wire pass could bind to the
					-- wrong clone. Stash the exact key in meta so ``_unregister``
					-- clears THIS entry on destroy.
					local regKey = _idWithPlacement(placement_id, inst.instance_id)
					self._componentByInstanceId[regKey] = comp
					self._meta[comp].registryKey = regKey
					table.insert(componentList, comp)
					-- Honor planner-supplied active/enabled/tag for prefab
					-- instances exactly as the scene boot path does (R3-P1.1).
					-- ``_injectHostSurface`` reads ``m.activeSelf`` /
					-- ``m.enabled`` to decide whether to overwrite with
					-- defaults; mirror the scene path so a prefab instance
					-- booted dormant (``enabled=false`` / ``active=false``)
					-- stays dormant until ``setEnabled`` / ``setActive``.
					self:_applyPlannerFlagsAndTag(comp, inst, goInst)
				end
			end
		end
	end
	for _, comp in ipairs(componentList) do
		local m = self._meta[comp]
		self:_injectHostSurface(comp, m and m.gameObjectInstance, m and m.gameObjectId)
	end
	self:_wireReferences(prefab.references or {}, componentByInstanceId, nil,
		instanceById, placement_id)
	-- Caller-supplied externals override matching wired refs.
	if type(externalRefs) == "table" then
		for instId, fields in pairs(externalRefs) do
			local comp = componentByInstanceId[instId]
			if comp and type(fields) == "table" then
				for k, v in pairs(fields) do
					comp[k] = v
				end
			end
		end
	end
	return componentList
end

-- ---------------------------------------------------------------------
-- Slice 1.3: client clone-site scale-faithful gravity correction
-- ---------------------------------------------------------------------
-- Mirror of the canonical ``correctDynamicAssembly`` helper baked into the
-- standalone ``SceneGravityCorrection`` server script
-- (``autogen._GRAVITY_CORRECTION_HELPER_LUAU``, §1.5). A clone produced by
-- ``instantiatePrefab`` is client-local (never replicated, never server-tagged),
-- so the server's boot sweep / ``DescendantAdded`` surfaces never see it -- the
-- client must correct its OWN clones at the clone site. The shared logic (force
-- formula + skip-rules + ``_ScaleGravityCorrected`` tag + carrier-first fact
-- resolution) is kept TOKEN-IDENTICAL to the canonical text; a parity test
-- (slice 1.4) pins the two emission sites against drift. Only the wiring differs
-- (a clone-site call here vs the server's boot sweep / spawn hook).
--
-- The mirrored text is embedded in a ``do`` block so its local ``factOf`` /
-- ``correctDynamicAssembly`` / ``_isBasePart`` shadow nothing at module scope;
-- ``correctDynamicAssembly`` is captured into a module-scope upvalue
-- (``_gravityCorrectDynamicAssembly``) so ``_correctClonedDynamics`` can call it.
local DEFAULT_UNITY_GRAVITY_Y = 9.81  -- |m_Gravity.y| Unity default (matches project_gravity.py)
local _gravityCorrectDynamicAssembly
do
	local TAG = "_ScaleGravityCorrected"
	local function _isBasePart(inst)
		return (type(inst) == "table" or type(inst) == "userdata")
			and inst:IsA("BasePart")
	end

	-- factOf: read attribute ``key`` off the carrier FIRST; only if ABSENT on the
	-- carrier, walk ancestor Models for the first holder (D-P1.6 root-first, then
	-- ancestor-Model walk). Covers S1/S5 (facts on the carrier) and S2 mesh-wrap
	-- (UseGravity stayed on the OUTER Model while only _UnityMass moved to the
	-- inner *_Mesh carrier). The fallback is gated PER-ATTRIBUTE on "absent on the
	-- carrier", NOT on an owning-Model lookup being nil -- so a factless parent
	-- container (S5) is never consulted before the carrier.
	local function factOf(carrier, key)
		local v = carrier:GetAttribute(key)
		if v ~= nil then
			return v
		end
		local owner = carrier:FindFirstAncestorWhichIsA("Model")
		while owner do
			local ov = owner:GetAttribute(key)
			if ov ~= nil then
				return ov
			end
			owner = owner:FindFirstAncestorWhichIsA("Model")
		end
		return nil
	end

	-- correctDynamicAssembly(carrier, desiredBaseStuds)
	-- ``carrier`` is the instance the scan found carrying _UnityMass: a BasePart
	-- (S1/S2/S4/S5) OR a Model carrier (S3/S6). Resolves a representative BasePart,
	-- then its AssemblyRootPart, applies one compensating VectorForce, and tags the
	-- root. Idempotent via the _ScaleGravityCorrected tag on the resolved root.
	local function correctDynamicAssembly(carrier, desiredBaseStuds)
		if type(carrier) ~= "table" and type(carrier) ~= "userdata" then
			return
		end
		-- 0. resolve a representative BasePart from the carrier.
		local representativePart
		if _isBasePart(carrier) then
			representativePart = carrier
		elseif carrier:IsA("Model") then
			-- Model carrier (S3 no-mesh-parent / S6 multi-sub-mesh): PrimaryPart,
			-- else the first descendant BasePart. In TODAY's converter output these
			-- descendants are Anchored (no own Rigidbody) so step 2 skips them.
			representativePart = carrier.PrimaryPart
				or carrier:FindFirstChildWhichIsA("BasePart", true)
			if representativePart == nil then
				-- No BasePart to resolve. Defensive one-shot skip WITHOUT tagging --
				-- the body stays correctable if it later becomes resolvable. (A
				-- Clone() yields a fully-materialized subtree before parenting, so
				-- this is not a deferral mechanism.)
				return
			end
		else
			return
		end
		if not _isBasePart(representativePart) then
			return
		end
		-- 1. resolve the assembly root (mirrors applyImpulse 1518-1532, but off the
		--    representativePart since a Model carrier has no .AssemblyRootPart).
		local root = representativePart.AssemblyRootPart or representativePart
		-- 2. SKIP rules (each a no-op return BEFORE any VectorForce creation).
		if root:GetAttribute(TAG) ~= nil then
			return  -- already corrected (dedup across all surfaces)
		end
		if root.Anchored then
			return  -- static geometry (also skips Model-carrier shapes S3/S6)
		end
		-- Humanoid / character rig: a Humanoid is never a BasePart ancestor, so use
		-- the ancestor-Model-contains-Humanoid form (NOT FindFirstAncestorWhichIsA
		-- ("Humanoid"), which is dead).
		local ancestorModel = root:FindFirstAncestorWhichIsA("Model")
		while ancestorModel do
			if ancestorModel:FindFirstChildWhichIsA("Humanoid") then
				return  -- character assembly -- leave on native gravity
			end
			ancestorModel = ancestorModel:FindFirstAncestorWhichIsA("Model")
		end
		local mass = root.AssemblyMass
		if mass <= 0 then
			return  -- SKIP WITHOUT TAGGING -- stays correctable if mass later valid
		end
		-- 3. read scale/skip facts CARRIER-FIRST then ancestor-Model walk (D-P1.6).
		local useGravityAttr = factOf(carrier, "UseGravity")
		-- GravityScale is a 2D-only fact (Rigidbody2D branch); DEAD for in-scope 3D
		-- (always nil ⇒ 1.0). Kept defensively / self-documenting.
		local gravityScaleAttr = factOf(carrier, "GravityScale")
		local gravityScale = (useGravityAttr == false) and 0 or (gravityScaleAttr or 1.0)
		local desiredStuds = desiredBaseStuds * gravityScale
		-- 4. compensating force: net accel = g_live - force/mass = desiredStuds.
		local force = mass * (workspace.Gravity - desiredStuds)
		-- 5. one Attachment + VectorForce on the root (ApplyAtCenterOfMass, World).
		local att = Instance.new("Attachment")
		att.Parent = root
		local vf = Instance.new("VectorForce")
		vf.Attachment0 = att
		vf.Force = Vector3.new(0, force, 0)
		vf.RelativeTo = Enum.ActuatorRelativeTo.World
		vf.ApplyAtCenterOfMass = true
		vf.Parent = root
		-- 6. tag the resolved root (dedup keyed on the physical assembly).
		root:SetAttribute(TAG, true)
	end

	_gravityCorrectDynamicAssembly = correctDynamicAssembly
end

function SceneRuntime:_correctClonedDynamics(clone)
	-- Correct each dynamic _UnityMass assembly in a freshly client-cloned prefab
	-- subtree, mirroring the server's class-agnostic scan + 2D exclusion. Selects
	-- on _UnityMass presence REGARDLESS of class (a BasePart S1/S2/S4 OR a Model
	-- carrier S3/S6) AND _Rigidbody2D == nil (Physics2D OOS -- a 2D body carries
	-- _UnityMass indistinguishably from a 3D one, so it is flagged + skipped).
	-- Walks clone:GetDescendants() PLUS the clone ROOT itself (a clone whose root
	-- IS a Model carrier is found by the root test, not the descendant walk).
	-- Because Clone() yields a fully-materialized subtree BEFORE clone.Parent is
	-- set, the representative part is present immediately -- no deferral needed for
	-- resolution. A Model-carrier clone resolves an Anchored representative part
	-- and is SKIPPED via skip-if-anchored, exactly as on the server.
	-- Guard the Instance API before indexing (mirrors the applyImpulse:1515
	-- indexability guard): a synthesized non-Instance clone (test harness, or a
	-- service that returns a plain table) must not hard-error here.
	if (type(clone) ~= "table" and type(clone) ~= "userdata")
		or type(clone.GetAttribute) ~= "function"
		or type(clone.GetDescendants) ~= "function" then
		return
	end
	local desiredBaseStuds = (self._plan and self._plan.gravityDesiredBaseStuds)
		or (STUDS_PER_METER * DEFAULT_UNITY_GRAVITY_Y)
	if clone:GetAttribute("_UnityMass") ~= nil
		and clone:GetAttribute("_Rigidbody2D") == nil then
		_gravityCorrectDynamicAssembly(clone, desiredBaseStuds)
	end
	for _, d in ipairs(clone:GetDescendants()) do
		if d:GetAttribute("_UnityMass") ~= nil
			and d:GetAttribute("_Rigidbody2D") == nil then
			_gravityCorrectDynamicAssembly(d, desiredBaseStuds)
		end
	end
end

function SceneRuntime:instantiatePrefab(prefab_id, parent, cframe, externalRefs)
	local prefab = (self._plan.prefabs or {})[prefab_id]
	if not prefab then
		self._warn(string.format(
			"[scene_runtime] instantiatePrefab: no prefab subplan for %q",
			tostring(prefab_id)))
		return nil
	end
	-- Clone the template via services (production: clone the
	-- ReplicatedStorage template; harness: synthesize a fake instance).
	local clone = self._services.clonePrefabTemplate(prefab_id, parent, cframe)
	if not clone then return nil end
	self._prefabClones[clone] = prefab_id

	-- Mint a runtime placement id so this clone's component maps don't
	-- collide with any other placement of the same prefab (scene-placed or
	-- another runtime spawn). ``_constructPrefabClone`` re-stamps each
	-- found descendant's ``_SceneRuntimeId`` to ``placement_id:goid`` so
	-- the read paths (``setActive`` / ``destroy`` / cascade) -- which all
	-- resolve via ``getInstanceId`` -> the stamped attribute -- agree on
	-- this clone's identity.
	self._rtPlacementSeq = self._rtPlacementSeq + 1
	local placement_id = "_rt_" .. tostring(self._rtPlacementSeq)

	-- Unfiltered construction (a runtime spawn isn't domain-gated), then
	-- run the lifecycle as its own batch.
	local componentList = self:_constructPrefabClone(
		clone, prefab, prefab_id, nil, externalRefs, placement_id)
	self:_runAwakeEnableStart(componentList)
	-- Slice 1.3: correct each dynamic _UnityMass assembly in this client-local
	-- clone (the server's boot sweep / DescendantAdded never sees a client clone).
	self:_correctClonedDynamics(clone)
	return clone
end

-- ---------------------------------------------------------------------
-- Slice 1.1: deferred UI-host gameObject resolution (generic boot race)
-- ---------------------------------------------------------------------
-- A UI-owned instance (``inst.instance_owner_is_ui == true``) binds its
-- host GameObject to a ScreenGui that Roblox clones StarterGui->PlayerGui
-- at spawn. At client boot the synchronous build loop can run BEFORE that
-- clone lands, so the one-shot ``workspaceFind`` returns nil. Building the
-- component with a nil gameObject crashes UI controllers (HudControl:46).
--
-- Rather than yield inside the build loop (which would break the
-- ``start() never yields`` invariant that keeps every batch's Awake/OnEnable
-- ahead of any deferred Start), we DEFER such missed UI instances entirely:
-- they are collected during the synchronous pass, then constructed +
-- lifecycled in their OWN batch from a spawned coroutine that waits
-- event-driven (``awaitUiHost`` -> ``PlayerGui.DescendantAdded``) for the
-- clone. Non-UI misses keep their current one-shot behaviour (built now
-- with a nil gameObject, no waiting, no timeout penalty).
--
-- SCOPE: initial boot only. ``instance.gameObject`` is bound once; the HUD
-- is ResetOnSpawn=false so its clone persists across respawns and no
-- rebind is needed. Respawn re-clone rebind (ResetOnSpawn=true GUIs) is an
-- explicit out-of-scope followup (see RUN_DIR/followups.md).

function SceneRuntime:_isUiOwned(inst)
	-- The planner stamps ``instance_owner_is_ui = true`` only on UI-subtree
	-- instances (the field is absent otherwise), so a strict ``== true``
	-- gate keeps every non-UI instance on the fast one-shot path.
	return inst ~= nil and inst.instance_owner_is_ui == true
end

function SceneRuntime:_applyPlannerFlagsAndTag(comp, inst, goInst)
	-- Honor planner-supplied active/enabled/tag for a freshly built
	-- component. Shared by the synchronous scene/prefab loops and the
	-- deferred-UI completion path so they stay byte-identical.
	local m = self._meta[comp]
	m.activeSelf = inst.active ~= false
	m.enabled = inst.enabled ~= false
	if inst.tag and inst.tag ~= "" then
		m.tag = inst.tag
		local list = self._byTag[inst.tag]
		if not list then list = {}; self._byTag[inst.tag] = list end
		local present = false
		for _, x in ipairs(list) do
			if x == goInst then present = true; break end
		end
		if goInst ~= nil and not present then
			table.insert(list, goInst)
		end
	end
end

function SceneRuntime:_deferUiInstance(entry)
	-- Collect a UI-owned instance whose synchronous ``workspaceFind``
	-- missed; ``_resolveDeferredUiInstances`` completes it after the
	-- synchronous boot.
	self._deferredUiInstances = self._deferredUiInstances or {}
	table.insert(self._deferredUiInstances, entry)
	-- Record the deferred instance_id (PLACEMENT-SCOPED, codex r3 BLOCKING) so
	-- the synchronous ``_wireReferences`` pass can flag inbound refs (peers
	-- that target this not-yet-built component) for back-patch once the
	-- deferred batch builds it. The key mirrors the engine registry key so a
	-- multi-placed deferred prefab tracks each placement separately.
	self._deferredInstanceIds = self._deferredInstanceIds or {}
	self._deferredInstanceIds[_idWithPlacement(entry.placement_id, entry.inst.instance_id)] = true
end

function SceneRuntime:_resolveDeferredUiInstances()
	-- Called AFTER the whole synchronous boot (all scene + prefab batches'
	-- Awake/OnEnable have run and their Starts are armed via task.defer).
	--
	-- The deferred UI instances are completed as a SINGLE late batch (NOT
	-- one independent lifecycle per component): we resolve every host clone
	-- first, then build/inject/wire the whole resolved set, then run
	-- ``_runAwakeEnableStart`` over it once -- so the batch's Awake/OnEnable
	-- all precede the batch's Start (Unity's intra-batch ordering), and the
	-- batch respects ``lifecycle_order`` among its own members. The batch is
	-- inherently LATE versus the synchronous batches (its hosts genuinely
	-- didn't exist at boot); that lateness is acceptable -- the ordering
	-- guarantee we must keep is intra-batch.
	local pending = self._deferredUiInstances
	if not pending or #pending == 0 then return end
	self._deferredUiInstances = nil

	local resolver = self._services.awaitUiHost
	local engine = self

	-- Group deferred entries by host (``gameObjectId``). Each host group is
	-- completed INDEPENDENTLY (codex r2 BLOCKING): the prior global barrier
	-- waited for ``remaining == 0`` across ALL pending entries, so one
	-- never-landing host stalled every already-resolved peer up to the 10s
	-- timeout. Per-host completion means a host that resolves promptly
	-- Awakes/Starts its own group right away, and a host that times out
	-- drops only its own group.
	--
	-- WITHIN a host group, the components still complete together as ONE
	-- ordered ``_runAwakeEnableStart`` mini-batch (r1 batching requirement):
	-- same-GO ``GetComponent``-in-Awake and ``lifecycle_order`` are
	-- preserved among same-host peers. Cross-host ordering is inherently
	-- best-effort -- different hosts resolve at different times.
	local groupOrder = {}
	local groups = {}
	for _, entry in ipairs(pending) do
		local key = entry.gameObjectId
		local group = groups[key]
		if not group then
			group = {}
			groups[key] = group
			table.insert(groupOrder, key)
		end
		table.insert(group, entry)
	end

	-- MAJOR (codex r3): dependency-aware ordering. With pure per-host grouping
	-- a group that holds an OUTBOUND ``component``-ref to a deferred component
	-- on ANOTHER host could Awake/Start with that ref nil (it only got
	-- eventually back-patched once the target's group reached Pass 3b). So
	-- before a group runs its lifecycle, it must wait for the groups that own
	-- its still-deferred component targets to complete. We compute the
	-- inter-group dependency edges here, then (1) topologically order the spawn
	-- so dependencies launch first (makes the synchronous-spawn harness path
	-- and the common case resolve without yielding) and (2) have each group's
	-- resolver WAIT for its dependency groups to finish before completing.
	-- KEY INVARIANT (do not regress the r2 BLOCKING fix): a group only waits on
	-- groups it actually references; UNRELATED groups never gate each other, so
	-- a never-resolving unrelated host cannot stall a resolved host.
	--
	-- ``instToGroup``: scoped deferred instance_id -> owning group key. Built
	-- from the same placement-scoped key as the engine registry so the
	-- target-ref lookup matches.
	local instToGroup = {}
	for key, group in pairs(groups) do
		for _, entry in ipairs(group) do
			local scoped = _idWithPlacement(
				entry.placement_id, entry.inst.instance_id)
			instToGroup[scoped] = key
		end
	end
	-- ``groupDeps[key]``: set of OTHER group keys this group depends on.
	local groupDeps = {}
	for key, group in pairs(groups) do
		-- The raw source instance_ids owned by this group (refs key ``from`` by
		-- raw prefab-local id). ``srcPresent`` is a membership set; ``srcPid``
		-- carries each source's placement_id to scope its targets (a nil
		-- placement_id -- scene entries -- must still register as present, so
		-- presence and placement are tracked separately).
		local srcPresent = {}
		local srcPid = {}
		for _, entry in ipairs(group) do
			srcPresent[entry.inst.instance_id] = true
			srcPid[entry.inst.instance_id] = entry.placement_id
		end
		local deps = {}
		for _, entry in ipairs(group) do
			for _, ref in ipairs(entry.references or {}) do
				if ref.target_kind == "component"
				   and srcPresent[ref["from"]] then
					local pid = srcPid[ref["from"]]
					local scopedTarget = ref.target_ref
					if pid ~= nil and pid ~= "" then
						scopedTarget = pid .. ":" .. ref.target_ref
					end
					local depKey = instToGroup[scopedTarget]
					if depKey ~= nil and depKey ~= key and not deps[depKey] then
						deps[depKey] = true
					end
				end
			end
		end
		groupDeps[key] = deps
	end

	-- Topologically order ``groupOrder`` so a group's dependencies spawn before
	-- it (Kahn's algorithm). A dependency CYCLE (or any leftover) is appended
	-- in the original stable order -- the per-group wait loop's timeout breaks
	-- the cycle at runtime (fail-closed: proceed with nil + warn, never hang).
	do
		local indeg = {}
		for _, key in ipairs(groupOrder) do indeg[key] = 0 end
		-- An edge dep -> key means key depends on dep; key's in-degree counts
		-- how many of its deps are still unscheduled.
		for key, deps in pairs(groupDeps) do
			for dep in pairs(deps) do
				if indeg[key] ~= nil then indeg[key] = indeg[key] + 1 end
			end
		end
		local queue = {}
		for _, key in ipairs(groupOrder) do
			if indeg[key] == 0 then table.insert(queue, key) end
		end
		local sorted = {}
		local scheduled = {}
		local qi = 1
		while qi <= #queue do
			local key = queue[qi]
			qi = qi + 1
			table.insert(sorted, key)
			scheduled[key] = true
			-- Relax every group that depends on ``key``.
			for other, deps in pairs(groupDeps) do
				if deps[key] and not scheduled[other] and indeg[other] ~= nil then
					indeg[other] = indeg[other] - 1
					if indeg[other] == 0 then table.insert(queue, other) end
				end
			end
		end
		-- Append any cycle remnant in the original order (stable).
		for _, key in ipairs(groupOrder) do
			if not scheduled[key] then table.insert(sorted, key) end
		end
		groupOrder = sorted
	end

	-- MAJOR (codex r1 #3): the defer branch is unconditional in the generic
	-- runtime, but ``awaitUiHost`` is injected only on the CLIENT services
	-- table. With no resolver (server domain, or any partition lacking the
	-- host-surface helper) we must NOT defer-then-never-build -- that
	-- regresses a server-domain UI-owned miss from "one-shot build (possibly
	-- nil gameObject)" to "never constructed". Restore the prior synchronous
	-- one-shot build for every deferred entry. We still resolve each host
	-- one-shot via ``workspaceFind`` in case the clone landed during the
	-- boot; on a miss the component is built with a nil gameObject exactly
	-- as the pre-slice one-shot path did.
	if not resolver then
		local oneShot = self._services.workspaceFind
		for _, key in ipairs(groupOrder) do
			local group = groups[key]
			local goInst = oneShot and oneShot(key) or nil
			for _, entry in ipairs(group) do
				entry.goInst = goInst
			end
			engine:_completeDeferredBatch(group)
		end
		return
	end

	-- Resolve each host clone in its own coroutine so the event-driven
	-- waits run concurrently and never block one another. When a host
	-- resolves, complete ITS group immediately as one mini-batch -- no
	-- cross-host barrier (except the explicit dependency wait below).
	--
	-- ``groupDone[key]`` flips true once a group has completed (or been
	-- skipped). A dependent group's resolver waits for its dependency groups'
	-- flags before completing, so its outbound ``component``-refs to deferred
	-- peers resolve in Pass 3a (non-nil at Awake/Start) instead of relying on
	-- the eventual inbound back-patch (codex r3 MAJOR).
	local groupDone = {}
	local task = self._services.task
	local spawn = task and task.spawn
	local waitFn = task and task.wait
	local nowFn = self._services.now
	-- Dependency wait budget. ``DEP_TIMEOUT`` bounds the real-time wait (a
	-- never-resolving dependency / cycle proceeds with nil + warn rather than
	-- hanging). ``DEP_MAX_ITERS`` is a harness-safe hard cap: the unit harness'
	-- ``task.wait`` returns without advancing ``now()``, so a clock-only
	-- deadline would spin forever there -- the iteration cap guarantees
	-- termination regardless of clock behaviour.
	local DEP_TIMEOUT = 10
	local DEP_MAX_ITERS = 200000
	local function waitForDeps(key)
		local deps = groupDeps[key]
		if not deps then return end
		local deadline = nowFn and (nowFn() + DEP_TIMEOUT) or nil
		for dep in pairs(deps) do
			local iters = 0
			while not groupDone[dep] do
				if deadline and nowFn and nowFn() >= deadline then
					engine._warn(string.format(
						"[scene_runtime] deferred group %q timed out waiting "
						.. "on dependency group %q; proceeding with nil refs",
						tostring(key), tostring(dep)))
					break
				end
				iters = iters + 1
				if iters >= DEP_MAX_ITERS then
					engine._warn(string.format(
						"[scene_runtime] deferred group %q exceeded wait budget "
						.. "on dependency group %q; proceeding with nil refs",
						tostring(key), tostring(dep)))
					break
				end
				if waitFn then waitFn(0.05) else break end
			end
		end
	end
	for _, key in ipairs(groupOrder) do
		local group = groups[key]
		local function resolveGroup()
			local goInst = resolver(key)
			for _, entry in ipairs(group) do
				entry.goInst = goInst
			end
			-- Wait for dependency groups to complete so this group's outbound
			-- component refs resolve before its lifecycle runs. Unrelated
			-- groups are NOT in ``groupDeps[key]`` so they never gate us.
			waitForDeps(key)
			engine:_completeDeferredBatch(group)
			groupDone[key] = true
		end
		if spawn then
			spawn(resolveGroup)
		else
			-- No task.spawn (harness without one): run inline. The resolver
			-- is responsible for not yielding in that environment.
			resolveGroup()
		end
	end
end

function SceneRuntime:_completeDeferredBatch(pending)
	-- Build/inject/wire every resolved deferred entry, then run the WHOLE
	-- set through ``_runAwakeEnableStart`` once. ``pending`` entries each
	-- carry their resolved ``entry.goInst`` (nil = host clone never landed).
	local engine = self
	-- Order the batch by the planner's ``lifecycle_order`` so deferred peers
	-- Awake in the authored order (and same-GO peers can see each other via
	-- GetComponent in Awake). ``lifecycle_order`` is per-scene; deferred
	-- entries may span scenes/prefabs, so we group-stable-sort: primary key
	-- the entry's position in its owner's ``lifecycle_order`` (missing =
	-- end), secondary the original defer order (stable).
	local orderIndex = {}
	for i, entry in ipairs(pending) do
		entry._deferSeq = i
		local lo = engine:_lifecycleOrderFor(entry)
		local idx = nil
		if lo then
			for pos, instId in ipairs(lo) do
				if instId == entry.inst.instance_id then idx = pos; break end
			end
		end
		orderIndex[entry] = idx
	end
	local ordered = {}
	for _, entry in ipairs(pending) do table.insert(ordered, entry) end
	table.sort(ordered, function(a, b)
		local ia, ib = orderIndex[a], orderIndex[b]
		if ia ~= nil and ib ~= nil and ia ~= ib then return ia < ib end
		if ia ~= nil and ib == nil then return true end
		if ia == nil and ib ~= nil then return false end
		return a._deferSeq < b._deferSeq
	end)

	-- Pass 1: build every entry whose host resolved; collect the batch.
	local batch = {}
	local builtByInstanceId = {}
	for _, entry in ipairs(ordered) do
		local inst = entry.inst
		local goInst = entry.goInst
		-- Clear the deferred marker as the target leaves the deferred state
		-- (built below, OR skipped on a nil host). The marker is set in
		-- ``_deferUiInstance`` and only consumed by the synchronous wire pass
		-- (already finished); keeping it honest means a never-built/destroyed
		-- target is no longer flagged as deferred. (harden: clear on every
		-- exit from deferred state, not only on a successful back-patch.)
		if engine._deferredInstanceIds ~= nil then
			engine._deferredInstanceIds[
				_idWithPlacement(entry.placement_id, inst.instance_id)] = nil
		end
		if goInst == nil then
			-- Fail-closed diagnostics: never bind nil silently. The
			-- component is simply not built (matches "UI legitimately
			-- absent"); a downstream nil-gameObject crash is avoided. (Only
			-- reached on the resolver path -- the no-resolver one-shot path
			-- builds even with nil to preserve the pre-slice behaviour.)
			if engine._services.awaitUiHost then
				engine._warn(string.format(
					"[scene_runtime] UI host clone for %q never landed; "
					.. "skipping deferred component %q",
					tostring(entry.gameObjectId),
					tostring(inst.script_id)))
			end
		end
		if goInst ~= nil or not engine._services.awaitUiHost then
			local comp = engine:_buildComponent(
				inst.script_id, goInst, entry.gameObjectId,
				(goInst and goInst.Name) or "", inst.config or {},
				entry.ownerKind, entry.ownerRef)
			if comp then
				entry.comp = comp
				builtByInstanceId[inst.instance_id] = comp
				-- MAJOR (codex r2): record in the engine-level registry so
				-- this deferred component is visible to later groups'
				-- outbound refs and inbound back-patches. PLACEMENT-SCOPED key
				-- (codex r3 BLOCKING) so a multi-placed deferred prefab doesn't
				-- collide; stash it in meta for ``_unregister``.
				local regKey = _idWithPlacement(entry.placement_id, inst.instance_id)
				engine._componentByInstanceId[regKey] = comp
				engine._meta[comp].registryKey = regKey
				-- MAJOR (codex r2): reapply planner ``active``/``enabled``/
				-- ``tag`` BEFORE ``_injectHostSurface``, matching the
				-- synchronous scene/prefab paths. Without this an authored
				-- ``enabled=false`` deferred UI woke ENABLED and ran
				-- OnEnable/Start, and its tag never entered ``_byTag``.
				engine:_applyPlannerFlagsAndTag(comp, inst, goInst)
				table.insert(batch, comp)
			end
		end
	end
	if #batch == 0 then return end

	-- Pass 2: inject host surface for every built component (mirrors the
	-- synchronous step 2: inject all before wiring any peer).
	for _, comp in ipairs(batch) do
		local m = engine._meta[comp]
		-- Scope: initial boot only. ``instance.gameObject`` is bound once
		-- here; the HUD is ResetOnSpawn=false so its clone persists across
		-- respawns. Respawn re-clone rebind is an out-of-scope followup.
		engine:_injectHostSurface(comp, m.gameObjectInstance, m.gameObjectId)
	end

	-- Pass 3a: wire each built component's OWN outbound references. Group by
	-- owner (references list + byInstanceId + placement) so a multi-entry
	-- batch wires every member's outbound refs in one pass per owner, with
	-- the full set of built peers visible (intra-batch component refs
	-- resolve to their freshly-built peer). The SOURCE gate stays
	-- ``builtByInstanceId`` (only THIS group's components get wired), but
	-- the TARGET resolve map is the engine-level union
	-- (``_componentByInstanceId``) so an outbound ``component``-kind ref to a
	-- SYNCHRONOUSLY-built peer (or an earlier deferred group) resolves --
	-- the mirror of the inbound back-patch (codex r2 BLOCKING).
	local wiredOwners = {}
	for _, entry in ipairs(ordered) do
		if entry.comp and entry.references and not wiredOwners[entry.references] then
			wiredOwners[entry.references] = true
			engine:_wireReferences(
				entry.references, builtByInstanceId,
				engine._crossDomainEdges, entry.byInstanceId,
				entry.placement_id, engine._componentByInstanceId)
		end
	end

	-- Pass 3b: back-patch INBOUND references -- synchronous (or earlier
	-- batch) sources whose serialized ref targeted a now-built deferred
	-- component got ``nil`` in the original ``_wireReferences`` pass and
	-- were recorded in ``_inboundRefsToDeferred``. Set the stored field on
	-- each source now. (A source that already CACHED the value in its Awake
	-- won't re-read it -- inherent; we ensure the field/ref is populated so
	-- re-reading consumers and the deferred component's own path work.)
	if engine._inboundRefsToDeferred then
		local kept = {}
		for _, rec in ipairs(engine._inboundRefsToDeferred) do
			-- harden: drop records whose source component has left ``_meta``
			-- (destroyed before this drain). Replaying the stored back-patch
			-- would mutate a dead component table -- the source is gone, so the
			-- record is garbage (neither replayed nor kept).
			if engine._meta[rec.source] ~= nil then
				-- ``rec.target_ref`` is the PLACEMENT-SCOPED key (codex r3); resolve
				-- against the engine union registry (also scoped) rather than the
				-- batch-local ``builtByInstanceId`` (raw-keyed) so the record binds
				-- the correct placement's clone -- and so a target built by ANY
				-- batch (cross-host) resolves, not only this one.
				local target = engine._componentByInstanceId[rec.target_ref]
				if target ~= nil then
					engine:_assignFieldOnComponent(
						rec.source, rec.field, rec.index, target)
				else
					-- Target not yet built (host never landed, or a multi-batch
					-- shape) -- keep the record for a later batch.
					table.insert(kept, rec)
				end
			end
		end
		engine._inboundRefsToDeferred = (#kept > 0) and kept or nil
	end
	-- Pass 3c: prefab-side externalRefs override matching wired fields,
	-- mirroring ``_constructPrefabClone``'s post-wire override.
	for _, entry in ipairs(ordered) do
		if entry.comp and type(entry.externalRefs) == "table" then
			local fields = entry.externalRefs[entry.inst.instance_id]
			if type(fields) == "table" then
				for k, v in pairs(fields) do
					entry.comp[k] = v
				end
			end
		end
	end

	-- Steps 3-5 over the WHOLE batch: Awake (all) -> OnEnable (all) ->
	-- Start (next tick). Running the whole batch through one
	-- ``_runAwakeEnableStart`` is what guarantees the batch's Awake/OnEnable
	-- precede its Start and that ``lifecycle_order`` holds among the batch.
	engine:_runAwakeEnableStart(batch)
end

function SceneRuntime:_lifecycleOrderFor(entry)
	-- Resolve the planner ``lifecycle_order`` list for a deferred entry's
	-- owner (scene or prefab) so ``_completeDeferredBatch`` can order the
	-- batch by it. Returns nil when no order is available (then defer order
	-- is used as a stable fallback).
	if entry.ownerKind == "scene" then
		local scene = (self._plan.scenes or {})[entry.ownerRef]
		return scene and scene.lifecycle_order
	elseif entry.ownerKind == "prefab" then
		local prefab = (self._plan.prefabs or {})[entry.ownerRef]
		return prefab and prefab.lifecycle_order
	end
	return nil
end

-- ---------------------------------------------------------------------
-- Boot: read the plan, drive every scene's lifecycle
-- ---------------------------------------------------------------------

function SceneRuntime:start(domainFilter)
	-- ``domainFilter`` filters modules by ``domain == filter``; the
	-- entrypoint passes ``"client"`` or ``"server"``. ``nil`` instantiates
	-- everything (used by the harness).
	local crossDomainEdges = {}

	-- Phase 0: collect runtime-bearing module ids for this side.
	local includeScriptId = {}
	for sid, row in pairs(self._plan.modules or {}) do
		if row.runtime_bearing
		   and row.domain ~= "legacy"
		   and row.domain ~= "excluded"
		   and row.domain ~= "helper" then
			if (domainFilter == nil) or (row.domain == domainFilter) then
				includeScriptId[sid] = true
			end
		end
	end

	local sceneOrder = {}
	for sceneKey, _ in pairs(self._plan.scenes or {}) do
		table.insert(sceneOrder, sceneKey)
	end
	table.sort(sceneOrder)   -- determinism

	for _, sceneKey in ipairs(sceneOrder) do
		local scene = self._plan.scenes[sceneKey]
		local componentByInstanceId = {}
		local lifecycleList = {}

		-- Step 1: construct every instance via new(config).
		local order = scene.lifecycle_order or {}
		-- Fallback: instance array order if no lifecycle_order.
		if #order == 0 then
			for _, inst in ipairs(scene.instances or {}) do
				table.insert(order, inst.instance_id)
			end
		end
		local byInstanceId = {}
		for _, inst in ipairs(scene.instances or {}) do
			byInstanceId[inst.instance_id] = inst
		end

		-- R5-P1.2: pre-pass populates ``_goParentId`` and seeds
		-- ``_goActiveSelf`` for every GameObject this scene's planner
		-- artifact knows about. We do this BEFORE constructing any
		-- instance so ``_injectHostSurface`` can walk the parent map
		-- upward when computing each component's
		-- boot-time ``activeInHierarchy``. Multiple components on the
		-- same GO share the per-GO entries (last writer wins, but the
		-- planner emits the same ``active`` + ``parent_game_object_id``
		-- for every component on a GO, so this is a no-op).
		for _, inst in ipairs(scene.instances or {}) do
			if includeScriptId[inst.script_id] then
				local goId = inst.game_object_id
				if goId then
					if self._goActiveSelf[goId] == nil then
						self._goActiveSelf[goId] = inst.active ~= false
					end
					local parentId = inst.parent_game_object_id
					if parentId and self._goParentId[goId] == nil then
						self._goParentId[goId] = parentId
					end
				end
			end
		end
		for _, instId in ipairs(order) do
			local inst = byInstanceId[instId]
			if inst and includeScriptId[inst.script_id] then
				local goInst = self._services.workspaceFind(inst.game_object_id)
				-- Slice 1.1: a UI-owned instance whose one-shot lookup
				-- missed defers to event-driven resolution (its
				-- StarterGui->PlayerGui clone may not have landed yet).
				-- Do NOT build it now with a nil gameObject. Non-UI misses
				-- fall through to the one-shot path below unchanged.
				if goInst == nil and self:_isUiOwned(inst) then
					self:_deferUiInstance({
						inst = inst,
						gameObjectId = inst.game_object_id,
						ownerKind = "scene",
						ownerRef = sceneKey,
						references = scene.references or {},
						byInstanceId = byInstanceId,
						placement_id = nil,
					})
				else
					local comp = self:_buildComponent(
						inst.script_id, goInst, inst.game_object_id,
						(goInst and goInst.Name) or "", inst.config or {},
						"scene", sceneKey)
					if comp then
						componentByInstanceId[instId] = comp
						-- Scene instance_ids are already globally unique (no
						-- placement namespacing needed); still record the key so
						-- ``_unregister`` clears the entry on destroy (codex r3).
						self._componentByInstanceId[instId] = comp
						self._meta[comp].registryKey = instId
						table.insert(lifecycleList, comp)
						self:_applyPlannerFlagsAndTag(comp, inst, goInst)
					end
				end
			end
		end

		-- Step 2: inject host surface + references (cycle-safe because
		-- step 1 touched no peers per the constructor-purity rule).
		for _, comp in ipairs(lifecycleList) do
			local m = self._meta[comp]
			self:_injectHostSurface(comp, m.gameObjectInstance, m.gameObjectId)
		end
		self:_wireReferences(scene.references or {}, componentByInstanceId,
			crossDomainEdges, byInstanceId)

		-- Steps 3-5: Awake -> OnEnable -> Start.
		self:_runAwakeEnableStart(lifecycleList)
	end

	-- Bug B tier 1: boot pre-placed prefab instances. The scene loop only
	-- walks logical scene GameObjects; PrefabInstance documents authored
	-- into the scene were never booted, so Door/Turret/animation scripts
	-- on pre-placed prefabs never ran. Each placement's clone already lives
	-- in the converted tree (stamped with prefab-local ``_SceneRuntimeId``s
	-- by ``scene_converter._convert_prefab_instance``); reuse the prefab
	-- component-construction path scoped to that clone, filtered by
	-- ``domainFilter`` (same gate as the scene loop), and run them as one
	-- more ``_runAwakeEnableStart`` batch. Appending a batch preserves the
	-- global Awake-before-Start ordering: ``_runAwakeEnableStart`` defers
	-- every ``Start`` via ``task.defer`` and ``start()`` never yields, so
	-- every batch's Awake/OnEnable runs before any batch's Start.
	local placements = self._plan.scene_prefab_placements or {}
	-- Determinism: sort placements by ``placement_id`` so boot order is
	-- stable across runs (the plan list order is parser-dependent).
	local placementOrder = {}
	for idx, placement in ipairs(placements) do
		table.insert(placementOrder, {idx = idx, id = placement.placement_id or ""})
	end
	table.sort(placementOrder, function(a, b)
		if a.id == b.id then return a.idx < b.idx end
		return a.id < b.id
	end)

	-- Multi-instance prefab placements all share the same template-level
	-- ``_SceneRuntimeId`` stamp (the converter does NOT mint a per-placement
	-- unique id today), so a naive ``workspaceFind`` returns the FIRST
	-- workspace clone for EVERY placement and only that one gets its
	-- MonoBehaviours wired. Track clones we've already bound and skip them
	-- on subsequent placements so each scene_prefab_placement binds to a
	-- DIFFERENT workspace clone. Ordering is workspace-iteration-stable;
	-- functionally each clone just needs ANY bound MonoBehaviour of the
	-- right type since per-placement configs from the same prefab are
	-- identical.
	local boundClones = {}
	local function _findUnboundClonePerPrefab(prefab, prefab_id)
		-- Discover the template's prefab-root file_id: the instance row whose
		-- parent_game_object_id is nil (or the smallest file_id in the
		-- subtree if everything has a parent — robust to planner shapes).
		local root_goid
		for _, inst in ipairs(prefab.instances or {}) do
			if inst.parent_game_object_id == nil then
				root_goid = inst.game_object_id
				break
			end
		end
		if not root_goid then
			-- Fallback: any instance's parent_game_object_id; pick one that
			-- ISN'T present as another instance's game_object_id (i.e. the
			-- root that hangs off the scene).
			local present = {}
			for _, inst in ipairs(prefab.instances or {}) do
				present[inst.game_object_id] = true
			end
			for _, inst in ipairs(prefab.instances or {}) do
				local p = inst.parent_game_object_id
				if p and not present[p] then root_goid = p; break end
			end
		end
		if not root_goid then return nil end
		-- Guard against the unit-test stub workspace, which doesn't
		-- implement ``GetDescendants`` / ``GetAttribute``.
		local ok, descs = pcall(function() return workspace:GetDescendants() end)
		if not ok or type(descs) ~= "table" then return nil end
		for _, d in ipairs(descs) do
			local sri_ok, sri = pcall(function() return d:GetAttribute("_SceneRuntimeId") end)
			if sri_ok and sri == root_goid and not boundClones[d] then
				boundClones[d] = true
				return d
			end
		end
		return nil
	end

	for _, entry in ipairs(placementOrder) do
		local placement = placements[entry.idx]
		local prefab_id = placement.prefab_id
		local prefab = (self._plan.prefabs or {})[prefab_id]
		if prefab then
			local p_placement_id = placement.placement_id or ""

			-- Resolve a workspace clone that no prior placement has bound; the
			-- scoped ``resolveCloneChild`` walk inside ``_constructPrefabClone``
			-- then finds the placement's specific sub-Instances. Falls back to
			-- ``nil`` (workspaceFind path) if no clone is found, preserving
			-- prior single-instance behaviour.
			local placement_clone = _findUnboundClonePerPrefab(prefab, prefab_id)

			-- Seed ``_goParentId``/``_goActiveSelf`` for the placement's
			-- GameObjects, parity with the scene boot pre-pass. Prefab
			-- instances carry prefab-local parent edges that we namespace
			-- with the placement id so each clone gets its own entries
			-- (the un-namespaced shape collided across placements); the
			-- placement ROOT additionally hangs off the scene parent
			-- GameObject (a scene id, NOT prefab-local) so the
			-- activeInHierarchy walk can reach into the scene tree.
			for _, inst in ipairs(prefab.instances or {}) do
				if includeScriptId[inst.script_id] then
					local goId = _idWithPlacement(
						p_placement_id, inst.game_object_id)
					if goId then
						if self._goActiveSelf[goId] == nil then
							self._goActiveSelf[goId] = (inst.active ~= false)
								and (placement.active ~= false)
						end
						local parentId = inst.parent_game_object_id
						if parentId == nil then
							-- Prefab root: bind it to the scene parent GO so
							-- the ancestor walk continues upward. The scene
							-- parent id is NOT prefab-local, so it stays
							-- un-namespaced.
							parentId = placement.parent_game_object_id
						else
							-- Intra-prefab edge: namespace it to match the
							-- child's namespaced goId.
							parentId = _idWithPlacement(p_placement_id, parentId)
						end
						if parentId and self._goParentId[goId] == nil then
							self._goParentId[goId] = parentId
						end
					end
				end
			end

			local componentList = self:_constructPrefabClone(
				placement_clone, prefab, prefab_id, includeScriptId, nil,
				p_placement_id, true)
			self:_runAwakeEnableStart(componentList)
		end
	end

	-- Step 6: update loops via heartbeat + fixed-step accumulator.
	if self._services.heartbeat then
		local engine = self
		self._heartbeatConn = self._services.heartbeat:Connect(function(dt)
			engine:_tick(dt)
		end)
	end

	self._crossDomainEdges = crossDomainEdges

	-- Slice 1.1: complete any UI-owned instances whose host clone hadn't
	-- landed during the synchronous boot. This runs AFTER every
	-- synchronous batch's Awake/OnEnable+armed Start, so the
	-- start()-never-yields invariant for those components is preserved; the
	-- deferred components run their own complete late lifecycle batch once
	-- their PlayerGui clone resolves event-driven.
	self:_resolveDeferredUiInstances()

	-- Build the host-owned per-player embodiment authority (paradigm C).
	-- Client-only + keyed on the upstream has_character_controller MODULE
	-- signal; leaves ``self._player = nil`` (the _tick brackets no-op) on the
	-- server or when identity is absent/ambiguous (fail-closed).
	self:_initPlayerAuthority()

	return crossDomainEdges
end

-- ---------------------------------------------------------------------
-- Host-owned per-player embodiment authority (paradigm C). Methods over
-- the ``self._player`` state table, driven from ``_tick`` OUTSIDE the
-- component ``pairs()`` loop (the ``_tick`` hooks + ``_initPlayerAuthority``
-- that build ``self._player`` and key it on the upstream
-- ``has_character_controller`` signal land in a later slice). Every method
-- here no-ops when ``self._player == nil`` (server side / no player).
--
-- Reuses the camera-input service's vetted pose MATH via the INJECTED pure
-- helpers ``self._services.cameraAdvance`` / ``cameraComposeLook`` (never a
-- top-of-file ``require`` — the host harness loads this module with no
-- ``game`` global) and reads ``self._services.userInputService`` for raw
-- mouse/key state. C owns the SINGLE per-frame E2E-channel read (D9): the
-- ACK-once mouse-channel consume lives in ``_playerReadInput`` here, NEVER
-- via the camera service's per-frame ``step`` / ``readDelta``.

-- One-time, idempotent client boot: take authoritative camera control,
-- lock the FPS mouse, disable Roblox's default PlayerModule controls, and
-- hide the local default avatar (folds the camera service's one-time
-- ``ensureInit`` body inline — per-player lifecycle resync on CharacterAdded
-- is Phase 3).
-- Reached only via the (later-slice) pre-tick bracket, which runs only when
-- ``self._player`` is non-nil, so the ``isClient`` gate is enforced upstream.
function SceneRuntime:_playerBoot()
	local p = self._player
	if not p or p._booted then return end
	p._booted = true

	-- E1b: ``workspace.CurrentCamera`` may be nil before the client camera
	-- materializes -- guard the write, never nil-deref.
	local cam = workspace.CurrentCamera
	if cam then cam.CameraType = Enum.CameraType.Scriptable end

	local uis = self._services.userInputService
	if uis then
		uis.MouseBehavior = Enum.MouseBehavior.LockCenter
		uis.MouseIconEnabled = false
	end

	-- Disable Roblox's default PlayerModule controls (it re-asserts
	-- MouseBehavior each frame otherwise) and hide the local default avatar,
	-- which is not the scene player rig.
	local players = self._services.players
	local lp = players and players.LocalPlayer
	local function applyControls()
		local ps = lp and lp:FindFirstChild("PlayerScripts")
		local pm = ps and ps:FindFirstChild("PlayerModule")
		if pm then
			local ok, mod = pcall(require, pm)
			if ok and mod then
				local ok2, controls = pcall(function() return mod:GetControls() end)
				if ok2 and controls and controls.Disable then
					pcall(function() controls:Disable() end)
				end
			end
		end
		if uis then
			uis.MouseBehavior = Enum.MouseBehavior.LockCenter
			uis.MouseIconEnabled = false
		end
	end
	local function hideChar(char)
		if not char then return end
		local function hide(part)
			if part:IsA("BasePart") or part:IsA("Decal") then
				part.LocalTransparencyModifier = 1
			end
		end
		char.DescendantAdded:Connect(hide)
		for _, part in char:GetDescendants() do hide(part) end
	end
	if lp then
		applyControls()
		hideChar(lp.Character)
		lp.CharacterAdded:Connect(function(char)
			-- Fast-respawn race (harden P1): a NEW character supersedes any prior
			-- char's pending late-HRP retry — cancel it before (re)acquiring, so an
			-- earlier char's late HRP can never stomp this char's yaw. When this
			-- char itself lacks an HRP, _playerArmLateHRPResync re-arms a fresh one.
			local pp = self._player
			if pp and pp._lateHRPConn then
				pp._lateHRPConn:Disconnect(); pp._lateHRPConn = nil
			end
			-- IMMEDIATE yaw+camera resync FIRST, BEFORE the yield (D7/P1-b) --
			-- so respawn yaw is correct the SAME frame (no stale-yaw frame).
			-- If the HRP has not replicated yet the immediate yaw reseed is
			-- skipped; arm a one-shot late-HRP retry (D-P3-late-hrp) so the yaw
			-- corrects the moment the HRP arrives (else it stays stale this life).
			if not self:_playerResyncToCharacter(char) then
				self:_playerArmLateHRPResync(char)
			end
			-- DELAYED: controls-off + body-hide LEGITIMATELY need the yield --
			-- applyControls needs PlayerScripts->PlayerModule (populated a frame
			-- after CharacterAdded) and hideChar walks char:GetDescendants()
			-- (fill in over the same window).
			self._services.task.wait()
			applyControls()
			hideChar(char)
		end)
		-- Boot-with-existing-character (P2-a): if lp.Character already EXISTS at
		-- boot (Studio test mode / fast spawn), CharacterAdded never fires for
		-- it, so seed facing once via the SAME shared resync -- facing correct
		-- from frame 0 (else _yaw stays at the init 0 until later input/respawn).
		-- Same late-HRP fallback as the CharacterAdded path: if the existing
		-- character's HRP has not replicated at boot, arm the one-shot retry so
		-- the boot facing corrects when it arrives (D-P3-late-hrp).
		if lp.Character then
			if not self:_playerResyncToCharacter(lp.Character) then
				self:_playerArmLateHRPResync(lp.Character)
			end
		end
	end
end

-- The SINGLE per-frame E2E-channel read (D9). Reads the raw mouse delta off
-- the injected ``userInputService`` AND the consume-once E2E channel on
-- ``workspace`` (mirroring the camera service's ``readDelta`` semantics but
-- OWNED here so C is the single consumer), then advances accumulated
-- yaw/pitch via the INJECTED pure ``cameraAdvance`` helper. NEVER calls the
-- camera service's per-frame ``step`` / ``readDelta``. Returns the raw
-- (dx, dy) for test assertions.
function SceneRuntime:_playerReadInput()
	local p = self._player
	if not p then return 0, 0 end

	local dx, dy = 0, 0
	local uis = self._services.userInputService
	if uis then
		local d = uis:GetMouseDelta()
		dx, dy = d.X, d.Y
	end

	-- Production-safe E2E channel (docs/E2E_INPUT_CHANNEL.md): additive,
	-- no-op when unset, acked exactly once so a same-frame second reader
	-- (the lowered A singleton) sees seq == ack and adds 0.
	local seq = workspace:GetAttribute("E2EMouseSeq") or 0
	if seq > (workspace:GetAttribute("E2EMouseAckSeq") or 0) then
		workspace:SetAttribute("E2EMouseAckSeq", seq)
		dx = dx + (workspace:GetAttribute("E2EMouseDeltaX") or 0)
		dy = dy + (workspace:GetAttribute("E2EMouseDeltaY") or 0)
	end

	p._yaw, p._pitch = self._services.cameraAdvance(
		p._yaw, p._pitch, dx, dy,
		p._sensitivity, p._minPitch, p._maxPitch
	)
	return dx, dy
end

-- Idempotent ``CurrentCamera`` write (called BOTH pre-Update and
-- post-LateUpdate). Eye = character HRP position + eyeHeight when it exists;
-- else the current camera position (degenerate, no character yet -- E1).
-- Re-asserts ``CameraType = Scriptable`` if drifted, then composes the look
-- via the INJECTED pure ``cameraComposeLook``. Pure function of the current
-- yaw/pitch (advanced once in ``_playerReadInput``), so two calls with
-- unchanged state yield the same pose (E9).
function SceneRuntime:_playerWriteCamera()
	local p = self._player
	if not p then return end

	-- E1b: guard a nil CurrentCamera (pre-materialize / no-camera context).
	local cam = workspace.CurrentCamera

	-- Eye source: follow the character's HRP when it exists; otherwise fall
	-- back to the current camera position (degenerate, E1/E10) so a missing
	-- character never nil-derefs.
	local eyePos
	local hrp = self:_playerCharacterHRP()
	if hrp then
		eyePos = hrp.Position + Vector3.new(0, p._eyeHeight, 0)
	elseif cam then
		eyePos = cam.CFrame.Position
	else
		eyePos = Vector3.zero
	end

	if cam then
		if cam.CameraType ~= Enum.CameraType.Scriptable then
			cam.CameraType = Enum.CameraType.Scriptable
		end
		cam.CFrame = self._services.cameraComposeLook(eyePos, p._yaw, p._pitch)
	end
end

-- Resolve the local player character's HumanoidRootPart for the camera eye.
-- Re-resolved each call (no stale cache) so a respawn re-follows the new
-- HRP; nil until the character exists (E1 -- no crash).
function SceneRuntime:_playerCharacterHRP()
	local players = self._services.players
	local lp = players and players.LocalPlayer
	local char = lp and lp.Character
	return char and char:FindFirstChild("HumanoidRootPart") or nil
end

-- IMMEDIATE per-player lifecycle resync (D7), shared by the CharacterAdded
-- handler AND the boot-with-existing-character path (§3.2/P2-a). Respawn itself
-- is SERVER-OWNED (autogen GameServer CharacterAdded spawn + engine
-- SpawnLocation); this is the CLIENT re-acquire: reseed yaw from the NEW
-- character's facing, zero pitch (mirrors scene_camera_input.onRespawn), and
-- re-assert the camera so it follows the NEW HRP THIS frame -- NO yield, so
-- there is no stale-yaw frame (D-P3-resync-ordering/P1-b). NO dependency on the
-- AI's ``PivotTo``, NO dependency on paradigm B. Guards a character with no HRP
-- yet (E9): leaves yaw unchanged, still zeroes pitch + re-asserts the camera.
-- RETURNS true when the HRP was present and the yaw was reseeded from it; false
-- when the HRP has not replicated yet (so the caller can arm a one-shot late-HRP
-- retry — D-P3-late-hrp). The pitch-zero + camera re-assert run unconditionally.
function SceneRuntime:_playerResyncToCharacter(char)
	local p = self._player
	if not p then return false end
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	local hadHrp = false
	if hrp and hrp.CFrame then
		-- Yaw reseed from the new character's facing via the INJECTED pure helper
		-- (D-P3-resync-helper); no re-derived yaw math in scene_runtime.luau.
		p._yaw = self._services.cameraYawOf(hrp.CFrame)
		hadHrp = true
	end
	p._pitch = 0
	-- _playerCharacterHRP re-resolves LocalPlayer.Character each call (no stale
	-- cache, 2968), so _playerWriteCamera now follows the NEW HRP automatically;
	-- re-assert the camera immediately so the resync is visible THIS frame.
	self:_playerWriteCamera()
	return hadHrp
end

-- Late-HRP fallback (D-P3-late-hrp): when the immediate resync ran on a character
-- whose HumanoidRootPart had not replicated yet, the yaw reseed was SKIPPED and
-- would otherwise stay STALE for that whole life (``_playerBoot`` is run-once, so
-- there is no later reseed). Arm a ONE-SHOT, event-driven ``char.DescendantAdded``
-- retry: the moment the HumanoidRootPart appears, reseed the yaw from its facing +
-- re-assert the camera, then DISCONNECT. Event-driven (no yield, no top-require) to
-- match the host model. No-op if the player authority is gone by the time it fires.
--
-- Fast-respawn lifecycle race (harden P1): a retry armed for char A must NOT stomp
-- a SUPERSEDING char B's yaw. Two guards: (1) tie the retry to the char it was armed
-- for — on HRP arrival only reseed when ``char`` is STILL ``LocalPlayer.Character``
-- (else a newer char has superseded it; just disconnect). (2) Cancel the prior
-- pending retry on re-arm: track the active retry connection on ``self._player``
-- (like ``_heartbeatConn``) and disconnect any prior pending retry before arming the
-- next, so only the newest char's retry can fire.
function SceneRuntime:_playerArmLateHRPResync(char)
	if not char or not char.DescendantAdded then return end
	local p = self._player
	if not p then return end
	-- Cancel any prior pending late-HRP retry (an earlier char's): only the
	-- newest char's retry should be live (guard 2).
	if p._lateHRPConn then p._lateHRPConn:Disconnect(); p._lateHRPConn = nil end
	local conn
	conn = char.DescendantAdded:Connect(function(desc)
		if not (desc and desc.Name == "HumanoidRootPart") then return end
		local thisConn = conn
		if conn then conn:Disconnect(); conn = nil end
		local pl = self._player
		if not pl then return end
		-- Clear the slot on fire ONLY when it still holds THIS retry's connection,
		-- so a newer char's re-armed retry (which overwrote ``_lateHRPConn``) is
		-- never clobbered. Compare against the captured ref, not the just-nilled
		-- upvalue.
		if pl._lateHRPConn == thisConn then pl._lateHRPConn = nil end
		-- Tie the retry to the char it was armed for (guard 1): only reseed when
		-- this char is STILL the current LocalPlayer.Character. If a newer char
		-- superseded it (fast respawn), its late HRP must NOT overwrite the newer
		-- char's yaw — just disconnect (done above).
		local players = self._services.players
		local lp = players and players.LocalPlayer
		if not lp or lp.Character ~= char then return end
		if desc.CFrame then
			pl._yaw = self._services.cameraYawOf(desc.CFrame)
		end
		-- Re-assert the camera so the corrected facing is visible the frame the
		-- HRP arrives (mirrors the immediate resync's camera re-assert).
		self:_playerWriteCamera()
	end)
	p._lateHRPConn = conn
end

-- Client teleport REQUEST (D7/D-P3-teleport, NON-load-bearing). Fires the
-- server-apply ``PlayerTeleport`` RemoteEvent with the requested CFrame; the
-- SERVER moves the character (the server owns the character CFrame -- mirrors the
-- server-owned spawn teleport in the autogen GameServer). No-op (silent) when the
-- player authority is not bound, the arg is not a CFrame, or the remote was never
-- injected -- the AI MAY never call this and the goal still holds because respawn
-- is server-owned (E7/AC5b). NO correctness path depends on this being called.
function SceneRuntime:_playerTeleport(cf)
	local p = self._player
	if not p then return end
	-- CFrame type-guard via the injected predicate (the autogen client services
	-- bind ``isCFrame`` to ``typeof(v) == "CFrame"``); injected (not a bare
	-- ``typeof``) so the standalone-luau harness -- whose loadstring'd chunk
	-- cannot override the ``typeof`` builtin -- can drive the real fire path.
	local isCFrame = self._services.isCFrame
	if isCFrame and not isCFrame(cf) then return end
	local remote = self._services.playerTeleportRemote   -- injected client-side; nil-safe
	if not (remote and remote.FireServer) then return end
	remote:FireServer(cf)
	-- Reseed the LOCAL authority facing from the REQUESTED pose (D-P3-teleport
	-- /phase-integration P1) -- ONLY now that the request was actually SENT, so
	-- when the remote is absent / lacks ``FireServer`` this stays a TRUE no-op
	-- (no fire AND no local-state mutation, per the documented contract). The
	-- server moves the HRP and U1 (slice 3.1) shadows the rig from it, but the
	-- camera/locomotion authority (``p._yaw``, ``p._pitch``) is CLIENT-owned and
	-- would otherwise keep the OLD facing — so camera/locomotion would not adopt
	-- the teleported yaw. Mirror ``_playerResyncToCharacter``: yaw from the
	-- INJECTED ``cameraYawOf`` (no re-derived yaw math), zero pitch. Sourced from
	-- ``cf`` (the requested pose) rather than the HRP, since the server move is
	-- asynchronous; a 1-frame eye-follow lag while the server moves the HRP is
	-- acceptable (teleport is non-load-bearing per D7) — the yaw is what must
	-- agree. Reseed the CAPTURED ``p`` (taken before the fire), not a re-read
	-- ``self._player``: a synchronous fire handler could have cleared the
	-- authority mid-fire, which would index-nil a re-read (real harness-model
	-- regression; unreachable with a real async Roblox RemoteEvent).
	p._yaw = self._services.cameraYawOf(cf)
	p._pitch = 0
end

-- Recoil kick on C's camera pitch. ``deltaPitchDeg`` is DEGREES — the unit the
-- directive contract binds (``applyRecoil(degrees)``): Unity recoil constants
-- are degrees and the AI's natural translation of ``camRotation.x -= 2`` is
-- ``applyRecoil(2)``; a radians surface turns that into a 114° clamp-slam
-- (observed at the Phase-5 cold-Studio verify). (``SceneCameraInput:
-- applyRecoil`` keeps radians — its caller is OUR lowering pass, which already
-- emits ``math.rad`` literals.) Additive, clamped to the player's pitch range;
-- a mid-Update kick survives to render because the post-tick camera write
-- composes from ``p._pitch``, and ``cameraAdvance`` carries the state forward.
-- No player / non-number delta -> no-op.
function SceneRuntime:_playerApplyRecoil(deltaPitchDeg)
	local p = self._player
	if not p then return end
	if type(deltaPitchDeg) ~= "number" then return end
	p._pitch = math.clamp(
		p._pitch + math.rad(deltaPitchDeg), p._minPitch, p._maxPitch)
end

-- Drive the character's locomotion once per frame, AFTER the LateUpdate pass
-- (the post bracket). WASD is camera-yaw-relative (same basis the lowered A
-- body uses: ``CFrame.Angles(0, yaw, 0):VectorToWorldSpace(Vector3.new(h, 0,
-- -v))`` with D/A -> +/-1 on h and W/S -> +/-1 on v) -> ``Humanoid:Move``.
--
-- JUMP (D-jump / E7 / P1-3 -- every-frame last-writer): the jump intent is
-- WRITTEN EVERY frame as ``humanoid.Jump = risingEdge`` -- true ONLY on the
-- frame Space transitions down, EXPLICITLY false otherwise. Because this runs
-- in the post-LateUpdate bracket it OVERWRITES paradigm A's level-triggered
-- ``hum.Jump = true`` (set mid-pass every grounded frame Space is held), so C
-- is the LAST jump writer every frame: on a held Space frame 1 ends true (the
-- press edge), frames 2+ end false -- one jump per press while still dominating
-- A. ``:ChangeState(Jumping)`` fires ONLY on the rising edge. ``p._jumpHeld`` is
-- the edge memory (NOT a write-suppressor: the Jump write happens every frame).
--
-- No character Humanoid yet -> no-op (E1). No-op when ``self._player == nil``.
function SceneRuntime:_playerDriveLocomotion()
	local p = self._player
	if not p then return end

	local players = self._services.players
	local lp = players and players.LocalPlayer
	local char = lp and lp.Character
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	if not hum then return end

	local uis = self._services.userInputService

	-- WASD -> camera-yaw-relative move direction (mirrors the lowered A body's
	-- yaw basis so C's move-intent matches the player's facing).
	local h, v = 0, 0
	if uis then
		if uis:IsKeyDown(Enum.KeyCode.D) then h = h + 1 end
		if uis:IsKeyDown(Enum.KeyCode.A) then h = h - 1 end
		if uis:IsKeyDown(Enum.KeyCode.W) then v = v + 1 end
		if uis:IsKeyDown(Enum.KeyCode.S) then v = v - 1 end
	end
	local dir = CFrame.Angles(0, p._yaw, 0):VectorToWorldSpace(
		Vector3.new(h, 0, -v))
	if dir.Magnitude > 0 then
		hum:Move(dir.Unit, false)
	else
		hum:Move(Vector3.zero, false)
	end

	-- JUMP -- every-frame last-writer (E7/P1-3). Compute the rising edge, then
	-- WRITE ``Jump`` every frame (true only on the edge) so C dominates A's
	-- mid-pass ``hum.Jump = true``; ``ChangeState(Jumping)`` only on the edge.
	local spaceDown = uis ~= nil and uis:IsKeyDown(Enum.KeyCode.Space) or false
	local risingEdge = spaceDown and not p._jumpHeld
	hum.Jump = risingEdge
	if risingEdge then
		hum:ChangeState(Enum.HumanoidStateType.Jumping)
	end
	p._jumpHeld = spaceDown
end

-- Read-only look for game logic (Phase 3 wires Shoot's raycast to this via
-- ``host.player``). STUB in Phase 2: mirrors ``CurrentCamera.CFrame``
-- whether or not ``self._player`` is bound (a no-player place still answers
-- a sane camera pose). E1b nil-guard preserved.
function SceneRuntime:getLookCFrame()
	local cam = workspace.CurrentCamera
	return cam and cam.CFrame or CFrame.new()
end

-- Pre-Update bracket (runs OUTSIDE the component ``pairs()`` loop, BEFORE
-- the Update pass). No-op when ``self._player == nil`` (server / no player).
-- Boots once (idempotent), reads the SINGLE per-frame E2E input snapshot
-- (D9 — before the lowered A controller's mid-pass ``_cam:step``->``_readDelta``
-- can consume the channel), then writes the camera so a same-frame raw camera
-- READ during the Update pass sees C's pose.
function SceneRuntime:_playerPreTick(_dt)
	if not self._player then return end
	self:_playerShadowSyncRig()
	self:_playerBoot()
	self:_playerReadInput()
	self:_playerWriteCamera()
end

-- U1 rig shadow-sync (player-embodiment-authority-design.md §Rig<->character
-- unification; D-P3-U1-shadow). Each frame, BEFORE the component Update pass,
-- drive every authored player-rig Instance to the character HRP CFrame, so the
-- AI's ``gameObject:GetPivot()`` reads see the ONE body (the character). The
-- component still LIVES on the authored rig Instance, so GetComponent /
-- _SceneRuntimeId / registry closures over the rig are PRESERVED (U1, NOT U2 --
-- we never rebind ``self.gameObject``). The AI's ``PivotTo`` writes are
-- overwritten next frame (vestigial; nothing authoritative reads rig yaw -- the
-- camera owns yaw via ``p._yaw``, AC1d). The rig is a POSITIONAL SHADOW of the
-- one body, NOT a second state store. No-op when no character yet (E1) or no rig
-- built (E2) -- never nil-derefs.
function SceneRuntime:_playerShadowSyncRig()
	if not self._player then return end
	local hrp = self:_playerCharacterHRP()
	if not hrp then return end                 -- no character yet -> nothing to shadow
	local cf = hrp.CFrame
	if cf == nil then return end
	for _, rig in ipairs(self:_playerRigInstances()) do
		if rig.PivotTo ~= nil then
			rig:PivotTo(cf)
		elseif rig.CFrame ~= nil then          -- BasePart rig (CharacterController->BasePart map)
			rig.CFrame = cf
		end
	end
end

-- Resolve the authored rig Instance(s) for the player module. Keyed ON the
-- deterministic upstream ``scriptId`` (the SAME MODULE row whose
-- ``has_character_controller`` is the §3 anchor -- NOT an AI-output fingerprint,
-- D-P3-rig-key). Scans ``self._meta`` for components whose
-- ``meta.scriptId == p._playerScriptId`` and returns their
-- ``meta.gameObjectInstance`` (the authored rig). Returns a LIST because one
-- player MODULE may be placed on >1 GameObject (P2-F: module count 1, instance
-- count N) -- U1 shadow-syncs ALL of them to the one character HRP. Empty when
-- the component isn't built yet (E2 -- no crash). De-dupes (multiple components
-- on one GO share a ``gameObjectInstance``).
function SceneRuntime:_playerRigInstances()
	local p = self._player
	if not p or not p._playerScriptId then return {} end
	local out, seen = {}, {}
	for _, m in pairs(self._meta) do
		if m.scriptId == p._playerScriptId then
			local inst = m.gameObjectInstance
			if inst ~= nil and not seen[inst] then
				seen[inst] = true
				table.insert(out, inst)
			end
		end
	end
	return out
end

-- Post-LateUpdate bracket (runs OUTSIDE the component ``pairs()`` loop, AFTER
-- the LateUpdate pass). No-op when ``self._player == nil``. Re-asserts the
-- camera (last-writer over any component camera write this frame — D8) folding
-- this frame's locomotion-driven eye position, then drives WASD->Move + the
-- every-frame last-writer jump.
function SceneRuntime:_playerPostTick(_dt)
	if not self._player then return end
	self:_playerWriteCamera()
	self:_playerDriveLocomotion()
end

-- Per-player lifecycle init (P1-2/P1-5/P2-F). Called ONCE at the end of
-- ``start()``. Builds ``self._player`` ONLY on the client side AND only when
-- the upstream ``has_character_controller`` signal identifies EXACTLY ONE
-- CC-bearing MODULE row over ``self._plan.modules`` (fail-closed otherwise):
--   * ``self._services.isClient`` not truthy  -> leave ``self._player = nil``
--     (the server never builds/drives the authority — the brackets no-op). The
--     gate is the explicit ``isClient`` boolean the entrypoint stamps, NOT a
--     ``RunService`` presence sniff (the server services table has no
--     ``runService``, so a presence sniff would mis-treat it as a client).
--   * 0 CC module rows -> no player (fail-closed silent; the build-time
--     ``player_signal_absent`` fail-close already catches this at convert time).
--   * >1 CC module rows -> warn + no player (ambiguous; mirrors the build-time
--     ``player_ambiguous`` fail-close — one camera per client).
--   * exactly 1 -> build the ``self._player`` state table (§1 shape).
-- Identity counts distinct CC MODULE rows (NOT per-instance ``_meta`` — one
-- CC module placed on N GameObjects is ONE row, not N), keyed ONLY on the
-- deterministic upstream ``row.has_character_controller`` signal — NEVER an
-- AI-output fingerprint (§3 guardrail).
function SceneRuntime:_initPlayerAuthority()
	self._player = nil
	if not self._services.isClient then return end

	local ccCount = 0
	-- Capture the player MODULE's scriptId (the deterministic upstream identity --
	-- the SAME row whose ``has_character_controller`` is the §3 anchor, NOT an
	-- AI-output fingerprint). U1's rig resolution (_playerRigInstances) keys on
	-- it. The ``>1`` branch below returns before the build, so exactly one
	-- scriptId reaches the state table.
	local playerScriptId = nil
	for sid, row in pairs(self._plan.modules or {}) do
		if type(row) == "table" and row.has_character_controller then
			ccCount = ccCount + 1
			playerScriptId = sid
		end
	end

	if ccCount == 0 then
		return
	elseif ccCount > 1 then
		self._warn(string.format(
			"[scene-runtime] player-embodiment authority unbound: %d modules "
			.. "carry has_character_controller (ambiguous; expected exactly "
			.. "one). No player camera/locomotion authority bound.", ccCount))
		return
	end

	self._player = {
		_yaw = 0,
		_pitch = 0,
		_booted = false,
		_jumpHeld = false,
		_sensitivity = 0.0045,
		_minPitch = math.rad(-80),
		_maxPitch = math.rad(80),
		_eyeHeight = 1.5,
		_playerScriptId = playerScriptId,   -- deterministic rig-resolution key (U1, §3)
	}
end

function SceneRuntime:_tick(dt)
	-- Host-owned player embodiment pre-Update bracket (no-op on server /
	-- no player) — runs BEFORE the component pass so C's input snapshot +
	-- camera write precede any component camera read this frame.
	self:_playerPreTick(dt)
	-- Update + LateUpdate every frame; FixedUpdate via fixed-step.
	for comp, m in pairs(self._meta) do
		if m.activeInHierarchy and m.enabled then
			self:_callMethod(comp, "Update", dt)
		end
	end
	self._fixedAccum = self._fixedAccum + dt
	while self._fixedAccum >= self._fixedStep do
		self._fixedAccum = self._fixedAccum - self._fixedStep
		for comp, m in pairs(self._meta) do
			if m.activeInHierarchy and m.enabled then
				self:_callMethod(comp, "FixedUpdate", self._fixedStep)
			end
		end
	end
	for comp, m in pairs(self._meta) do
		if m.activeInHierarchy and m.enabled then
			self:_callMethod(comp, "LateUpdate", dt)
		end
	end
	-- Host-owned player embodiment post-LateUpdate bracket — runs AFTER the
	-- component pass so C is the LAST writer of camera + move + jump intent.
	self:_playerPostTick(dt)
end

-- ---------------------------------------------------------------------
-- Cross-domain edge report (consumed by write_output)
-- ---------------------------------------------------------------------

function SceneRuntime:crossDomainEdges()
	return self._crossDomainEdges or {}
end

return SceneRuntime
